@printString:
 Local variables
	arg 0: str (u8*/8)
	; 6 pc
	move r6, r1
	move r1, r6
	call r0 = strlen[r1] -> i64
	move r1, r6
	move r2, r0
	call printStringLength[r1, r2]

@printChar:
 Local variables
	arg 0: chr (u8/1)
	; 8 pc
	addrof r6, chr
	const r2, 1
	move chr, r1
	move r1, r6
	call printStringLength[r1, r2]

@printUint:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 25 pc
	const r6, 20
	; 13:2 while true
@while_1:
	dec r6
	const r7, 10
	move r3, r1
	move r0, r3
	mod r2, r0, r7
	move r3, r2
	const r7, 10
	move r0, r1
	div r0, r0, r7
	move r1, r0
	cast r7(u8), r3(i64)
	const r0, 48
	add r7, r7, r0
	cast r0(i64), r6(u8)
	cast r0(u8*), r0(i64)
	addrof r3, [buffer]
	add r3, r3, r0
	store [r3], r7
	; 19:3 if number == 0
	equals r7, r1, 0
	branch r7, false, @while_1
	cast r7(i64), r6(u8)
	cast r7(u8*), r7(i64)
	addrof r1, [buffer]
	add r1, r1, r7
	const r7, 20
	sub r7, r7, r6
	cast r2(i64), r7(u8)
	call printStringLength[r1, r2]

@printIntLf:
 Local variables
	arg 0: number (i64/8)
	; 8 pc
	move r6, r1
	; 27:2 if number < 0
	lt r7, r6, 0
	branch r7, false, @if_3_end
	const r1, 45
	call printChar[r1]
	neg r6, r6
@if_3_end:
	move r1, r6
	call printUint[r1]
	const r1, 10
	call printChar[r1]

@strlen:
 Local variables
	arg 0: str (u8*/8)
	; 10 pc
	const r0, 0
	; 37:2 for *str != 0
	jump @for_4
@for_4_body:
	inc r0
	cast r2(i64), r1(u8*)
	const r3, 1
	move r1, r2
	add r1, r1, r3
	cast r1(u8*), r1(i64)
@for_4:
	load r2, [r1]
	notequals r2, r2, 0
	branch r2, true, @for_4_body
	; 40:9 return length

@main:
 Local variables
	var 0: c (i16/2)
	var 1: d (i16/2)
	var 2: t (bool/1)
	var 3: f (bool/1)
	var 4: b1 (u8/1)
	; 212 pc
	; begin initialize global variables
	; end initialize global variables
	const r1, [string-0]
	call printString[r1]
	const r6, 0
	const r7, 1
	const r0, 2
	move c, r0
	const r0, 3
	move d, r0
	const r0, 1
	move t, r0
	const r0, 0
	move f, r0
	move r0, r6
	and r0, r0, r6
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r6
	and r0, r0, r7
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r7
	and r0, r0, r6
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r7
	and r0, r0, r7
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	const r1, [string-1]
	call printString[r1]
	move r0, r6
	or r0, r0, r6
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r6
	or r0, r0, r7
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r7
	or r0, r0, r6
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r7
	or r0, r0, r7
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	const r1, [string-2]
	call printString[r1]
	move r0, r6
	xor r0, r0, r6
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r6
	move r2, c
	xor r0, r0, r2
	move c, r2
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r7
	xor r0, r0, r6
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r6, r7
	move r0, c
	xor r6, r6, r0
	move c, r0
	cast r1(i64), r6(i16)
	call printIntLf[r1]
	const r1, [string-3]
	call printString[r1]
	; 26:15 logic and
	move r6, f
	move r0, r6
	branch r0, false, @and_next_5
	move r0, r6
@and_next_5:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	; 27:15 logic and
	move r0, r6
	branch r0, false, @and_next_6
	move r0, t
	move t, r0
@and_next_6:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	; 28:15 logic and
	move r0, t
	move r2, r0
	move t, r0
	branch r2, false, @and_next_7
	move r2, r6
@and_next_7:
	cast r1(i64), r2(bool)
	call printIntLf[r1]
	; 29:15 logic and
	move r0, t
	move r2, r0
	branch r2, false, @and_next_8
	move r2, r0
	move t, r0
@and_next_8:
	cast r1(i64), r2(bool)
	call printIntLf[r1]
	const r1, [string-4]
	call printString[r1]
	; 31:15 logic or
	move r0, r6
	branch r0, true, @or_next_9
	move r0, r6
@or_next_9:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	; 32:15 logic or
	move r0, r6
	branch r0, true, @or_next_10
	move r0, t
	move t, r0
@or_next_10:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	; 33:15 logic or
	move r0, t
	move r2, r0
	move t, r0
	branch r2, true, @or_next_11
	move r2, r6
@or_next_11:
	cast r1(i64), r2(bool)
	call printIntLf[r1]
	; 34:15 logic or
	move r0, t
	move r2, r0
	branch r2, true, @or_next_12
	move r2, r0
	move t, r0
@or_next_12:
	cast r1(i64), r2(bool)
	call printIntLf[r1]
	const r1, [string-5]
	call printString[r1]
	notlog r6, r6
	cast r1(i64), r6(bool)
	call printIntLf[r1]
	move r6, t
	notlog r6, r6
	cast r1(i64), r6(bool)
	call printIntLf[r1]
	const r1, [string-6]
	call printString[r1]
	const r6, 10
	const r0, 6
	const r2, 1
	and r6, r6, r0
	or r6, r6, r2
	move b1, r2
	cast r1(i64), r6(u8)
	call printIntLf[r1]
	; 43:20 logic or
	move r6, c
	equals r0, r7, r6
	branch r0, true, @or_next_13
	move r0, d
	lt r0, r6, r0
	move d, r0
@or_next_13:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	; 44:20 logic and
	equals r0, r7, r6
	branch r0, false, @and_next_14
	move r0, d
	lt r0, r6, r0
@and_next_14:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	const r6, -1
	cast r1(i64), r6(i16)
	call printIntLf[r1]
	neg r6, r7
	cast r1(i64), r6(i16)
	call printIntLf[r1]
	move r6, b1
	not r6, r6
	cast r1(i64), r6(u8)
	call printIntLf[r1]

@printStringLength:
	mov     rdi, rsp
	
	mov     r8, rdx
	mov     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

String literals
	string lit 0 "Bit-&:\n\0"
	string lit 1 "\nBit-|:\n\0"
	string lit 2 "\nBit-^:\n\0"
	string lit 3 "\nLogic-&&:\n\0"
	string lit 4 "\nLogic-||:\n\0"
	string lit 5 "\nLogic-!:\n\0"
	string lit 6 "\nmisc:\n\0"
