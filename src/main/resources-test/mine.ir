	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

@getChar:
	sub    rsp, 28h
	  call [_getch]
	  test al, al
	  js   .1
	  jnz  .2
	  dec  al
	.1:
	  mov  rbx, rax
	  shl  rbx, 8
	  call [_getch]
	  or   rax, rbx
	.2:
	add    rsp, 28h
	ret

@setCursor@i16@i16:
	sub     rsp, 28h
	shl     rcx, 16
	movsxd  rcx, ecx
	movsx   rdx, dx
	add     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	call   [SetConsoleCursorPosition]
	add     rsp, 28h
	ret

