@printString:
 Local variables
	arg 0: str
	var 1: chr
	var 2: t.2
	var 3: t.3
	; 23 pc
	; 2:2 while true
@while_1:
	load chr(1@function,u8), [str(0@argument,u8*)]
	; 4:3 if chr == 0
	const t.3(3@function,u8), 0
	equals t.2(2@function,bool), chr(1@function,u8), t.3(3@function,u8)
	branch t.2(2@function,bool), false, @if_2_end
	jump @while_1_break
@if_2_end:
	call _, printChar [chr(1@function,u8)]
	jump @while_1
@while_1_break:
@printString_ret:

@printStringLength:
