@printChar:
	ld   r0, SPH
	ld   r1, SPL
	add  r1, 3
	adc  r0, 0
	ldc  r1, @rr0
	ld   %15, r1
	jp   %0818

@main:
 Local variables
	var 0: second
	var 1: chr
	var 2: t.2
	var 3: t.3
	; 31 pc
	; begin initialize global variables
	const text(0@global,u8*), [string-0]
	; end initialize global variables
	call _, printString [text(0@global,u8*)]
	call _, printLength []
	const t.2(2@function,i16), 1
	addrof second(0@function,u8*), [text(0@global,u8*) + t.2(2@function,i16)]
	call _, printString [second(0@function,u8*)]
	load chr(1@function,u8), [text(0@global,u8*)]
	cast t.3(3@function,i16), chr(1@function,u8)
	call _, printIntLf [t.3(3@function,i16)]
@main_ret:

