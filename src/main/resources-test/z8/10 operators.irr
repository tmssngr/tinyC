	neg r0(i16 number), r0(i16 number)
	copy number(0@argument,i16), r0(i16 number)
@if_6_end:
	call _, printUint [number(0@argument,i16)]
	const r0(u8 t.4), 10
	call _, printChar [r0(u8 t.4)]

@printChar:
	ld   r0, SPH
	ld   r1, SPL
	add  r1, 3
	adc  r0, 0
	ldc  r1, @rr0
	ld   %15, r1
	jp   %0818

