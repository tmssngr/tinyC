	load r0(u8 t.19), [r0(u8* t.20)]
	const r1(u8 t.23), 1
	shiftleft r0(u8 t.18), r0(u8 t.19), r1(u8 t.23)
	const r1(i16 t.26), 1
	cast r1(u8* t.27), r1(i16 t.26)
	addrof r2(u8* t.25), [board(0@global,u8*)]
