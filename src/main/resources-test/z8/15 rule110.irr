@printString:
 Local variables
	arg 0: str
	var 1: chr
	; 15 pc
@while_1:
	copy r0(u8* str), str(0@argument,u8*)
	load r1(u8 chr), [r0(u8* str)]
	; 4:3 if chr == 0
	const r2(u8 t.3), 0
	equals r2(bool t.2), r1(u8 chr), r2(u8 t.3)
	copy chr(1@function,u8), r1(u8 chr)
	branch r2(bool t.2), false, @if_2_end
	jump @printString_ret
@if_2_end:
	call _, printChar [chr(1@function,u8)]
	jump @while_1
@printString_ret:

@printChar:
	ld   r0, SPH
	ld   r1, SPL
	add  r1, 3
	adc  r0, 0
	ldc  r1, @rr0
	ld   %15, r1
	jp   %0818

@printBoard:
 Local variables
	var 0: i
	; 33 pc
	const r0(u8 t.1), 124
	call _, printChar [r0(u8 t.1)]
	const r0(u8 i), 0
	; 11:2 for i < 30
	copy i(0@function,u8), r0(u8 i)
@for_3:
	const r0(u8 t.3), 30
	copy r1(u8 i), i(0@function,u8)
	lt r0(bool t.2), r1(u8 i), r0(u8 t.3)
	branch r0(bool t.2), false, @for_3_break
	; 12:3 if [...] == 0
	copy r0(u8 i), i(0@function,u8)
	cast r1(i16 t.7), r0(u8 i)
	cast r1(u8* t.8), r1(i16 t.7)
	addrof r2(u8* t.6), [board(0@global,u8*)]
	add r1(u8* t.6), r2(u8* t.6), r1(u8* t.8)
	load r1(u8 t.5), [r1(u8* t.6)]
	const r2(u8 t.9), 0
	equals r1(bool t.4), r1(u8 t.5), r2(u8 t.9)
	branch r1(bool t.4), false, @if_4_else
	const r0(u8 t.10), 32
	call _, printChar [r0(u8 t.10)]
	jump @for_3_continue
@if_4_else:
	const r0(u8 t.11), 42
	call _, printChar [r0(u8 t.11)]
@for_3_continue:
	const r0(u8 t.12), 1
	copy r1(u8 i), i(0@function,u8)
	add r0(u8 i), r1(u8 i), r0(u8 t.12)
	copy i(0@function,u8), r0(u8 i)
	jump @for_3
@for_3_break:
	const r0(u8* t.13), [string-0]
	call _, printString [r0(u8* t.13)]

@main:
