	cast r2(u8* t.9), r2(i16 t.8)
	addrof r3(u8* t.7), [board(0@global,u8*)]
	add r2(u8* t.7), r3(u8* t.7), r2(u8* t.9)
	store [r2(u8* t.7)], r0(u8 t.6)
	const r0(u8 t.10), 1
	copy r1(u8 i), i(0@function,u8)
