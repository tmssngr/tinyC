@printStringLength:
 Local variables
	arg 0: str (u8*/2)
	arg 1: length (u8/1)
	var 2: chr (u8/1)
	var 3: t.3 (bool/1)
	; 23 pc
	; 13:2 while length > 0
@while_1:
	gt t.3, length, 0
	branch t.3, false, @while_1_break
	load chr, [str]
	call printChar[chr]
	dec length
	jump @while_1
@while_1_break:
@printStringLength_ret:

@printUint:
 Local variables
	arg 0: number (i16/2)
	var 1: buffer[] (u8*/20)
	var 2: pos (u8/1)
	var 3: remainder (i64/8)
	var 4: digit (u8/1)
	var 5: t.5 (i16/2)
	var 6: t.6 (i16/2)
	var 7: t.7 (i16/2)
	var 8: t.8 (u8/1)
	var 9: t.9 (u8/1)
	var 10: t.10 (u8*/2)
	var 11: t.11 (i16/2)
	var 12: t.12 (u8*/2)
	var 13: t.13 (bool/1)
	var 14: t.14 (u8*/2)
	var 15: t.15 (i16/2)
	var 16: t.16 (u8*/2)
	var 17: t.17 (u8/1)
	var 18: t.18 (u8/1)
	; 129 pc
	const pos, 20
	; 24:2 while true
@while_2:
	dec pos
	const t.6, 10
	move t.5, number
	mod t.5, t.5, t.6
	cast remainder(i64), t.5(i16)
	const t.7, 10
	div number, number, t.7
	cast t.8(u8), remainder(i64)
	const t.9, 48
	move digit, t.8
	add digit, digit, t.9
	cast t.11(i16), pos(u8)
	cast t.12(u8*), t.11(i16)
	addrof t.10, [buffer]
	add t.10, t.10, t.12
	store [t.10], digit
	; 30:3 if number == 0
	equals t.13, number, 0
	branch t.13, false, @if_3_end
	jump @while_2_break
@if_3_end:
	jump @while_2
@while_2_break:
	cast t.15(i16), pos(u8)
	cast t.16(u8*), t.15(i16)
	addrof t.14, [buffer]
	add t.14, t.14, t.16
	const t.18, 20
	move t.17, t.18
	sub t.17, t.17, pos
	call printStringLength[t.14, t.17]
@printUint_ret:

@main:
 Local variables
	var 0: onePtr (u8*/2)
	var 1: twoPtr (u8*/2)
	var 2: t.2 (u8/1)
	var 3: t.3 (u8/1)
	var 4: t.4 (u8*/2)
	var 5: t.5 (i16/2)
	var 6: t.6 (u8*/2)
	var 7: t.7 (i16/2)
	var 8: t.8 (u8/1)
	; 71 pc
	; begin initialize global variables
	const zero, 48
	const one, 49
	const two, 50
	const threeFour, 34
	; end initialize global variables
	call printChar[zero]
	addrof onePtr, one
	load t.2, [onePtr]
	call printChar[t.2]
	addrof twoPtr, two
	const t.5, 0
	cast t.6(u8*), t.5(i16)
	move t.4, twoPtr
	add t.4, t.4, t.6
	load t.3, [t.4]
	call printChar[t.3]
	cast t.7(i16), threeFour(u8)
	call printUint[t.7]
	const t.8, 10
	call printChar[t.8]
@main_ret:

@printChar:
	ld   r0, SPH
	ld   r1, SPL
	add  r1, 3
	adc  r0, 0
	ldc  r1, @rr0
	ld   %15, r1
	jp   %0818

Global variables
	0: zero (u8/1)
	1: one (u8/1)
	2: two (u8/1)
	3: threeFour (u8/1)

