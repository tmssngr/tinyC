@printString:
 Local variables
	arg 0: str (u8*/2)
	; 8 pc
	move r8, r0
	; 2:2 while true
	jump @while_1
@if_2_end:
	move r0, r10
	call printChar[r0]
@while_1:
	load r10, [r8]
	; 4:3 if chr == 0
	equals r0, r10, 0
	branch r0, false, @if_2_end

@printNibble:
 Local variables
	arg 0: x (u8/1)
	; 6 pc
	const r8, 15
	and r0, r0, r8
	; 5:2 if x > 9
	gt r8, r0, 9
	branch r8, false, @if_3_end
	add r0, 7
@if_3_end:
	add r0, 48
	call printChar[r0]

@printHex2:
 Local variables
	arg 0: x (u8/1)
	; 6 pc
	move r8, r0
	const r9, 4
	move r0, r8
	shiftright r0, r0, r9
	call printNibble[r0]
	move r0, r8
	call printNibble[r0]

@main:
	; 36 pc
	; begin initialize global variables
	; end initialize global variables
	const r0, [string-0]
	call printString[r0]
	const r8, 0
	; 19:2 for i < 16
	jump @for_4
@for_4_body:
	; 20:3 if i & 7 == 0
	const r9, 7
	move r10, r8
	and r10, r10, r9
	equals r9, r10, 0
	branch r9, false, @if_5_end
	const r0, 32
	call printChar[r0]
@if_5_end:
	move r0, r8
	call printNibble[r0]
	inc r8
@for_4:
	lt r9, r8, 16
	branch r9, true, @for_4_body
	const r0, 10
	call printChar[r0]
	const r8, 32
	; 27:2 for i < 128
	jump @for_6
@for_6_body:
	; 28:3 if i & 15 == 0
	const r9, 15
	move r10, r8
	and r10, r10, r9
	equals r9, r10, 0
	branch r9, false, @if_7_end
	move r0, r8
	call printHex2[r0]
@if_7_end:
	; 31:3 if i & 7 == 0
	const r9, 7
	move r10, r8
	and r10, r10, r9
	equals r9, r10, 0
	branch r9, false, @if_8_end
	const r0, 32
	call printChar[r0]
@if_8_end:
	move r0, r8
	call printChar[r0]
	; 35:3 if i & 15 == 15
	const r9, 15
	move r10, r8
	and r10, r10, r9
	equals r9, r10, 15
	branch r9, false, @for_6_continue
	const r0, 10
	call printChar[r0]
@for_6_continue:
	inc r8
@for_6:
	lt r0, r8, 128
	branch r0, true, @for_6_body

@printChar:
	ld   r0, SPH
	ld   r1, SPL
	add  r1, 3
	adc  r0, 0
	ldc  r1, @rr0
	ld   %15, r1
	jp   %0818

String literals
	string lit 0 " x\0"
