@while_1:
	const t.4(4@function,u8), 0
	gt t.3(3@function,bool), length(1@argument,u8), t.4(4@function,u8)
	branch t.3(3@function,bool), false, @while_1_break
	load chr(2@function,u8), [str(0@argument,u8*)]
