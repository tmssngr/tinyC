	addrof t.11(11@function,u8*), [buffer(1@function,u8*)]
	add t.11(11@function,u8*), t.11(11@function,u8*), t.13(13@function,u8*)
	store [t.11(11@function,u8*)], digit(4@function,u8)
	; 30:3 if number == 0
