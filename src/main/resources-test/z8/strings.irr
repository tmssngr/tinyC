@printString:
 Local variables
	arg 0: str (u8*/8)
	; 8 pc
	move r8, r0
	; 2:2 while true
	jump @while_1
@if_2_end:
	move r0, r9
	call printChar[r0]
@while_1:
	load r9, [r8]
	; 4:3 if chr == 0
	const r0, 0
	equals r0, r9, r0
	branch r0, false, @if_2_end

@printStringLength:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 9 pc
	move r8, r0
	move r9, r2
	; 13:2 while length > 0
	jump @while_3
@while_3_body:
	load r0, [r8]
	call printChar[r0]
	dec r9
@while_3:
	const r0, 0
	gt r0, r9, r0
	branch r0, true, @while_3_body

@printUint:
 Local variables
	arg 0: number (i16/2)
	var 1: buffer[] (u8*/20)
	; 22 pc
	const r8, 20
	; 24:2 while true
@while_4:
	dec r8
	const r9, 10
	move r10, r0
	mod r10, r10, r9
	cast r9(i64), r10(i16)
	const r10, 10
	div r0, r0, r10
	cast r9(u8), r9(i64)
	const r10, 48
	add r9, r9, r10
	cast r10(i16), r8(u8)
	cast r10(u8*), r10(i16)
	addrof r11, [buffer]
	add r11, r11, r10
	store [r11], r9
	; 30:3 if number == 0
	const r9, 0
	equals r9, r0, r9
	branch r9, false, @while_4
	cast r9(i16), r8(u8)
	cast r9(u8*), r9(i16)
	addrof r0, [buffer]
	add r0, r0, r9
	const r9, 20
	move r2, r9
	sub r2, r2, r8
	call printStringLength[r0, r2]

@printIntLf:
 Local variables
	arg 0: number (i16/2)
	; 8 pc
	move r8, r0
	; 38:2 if number < 0
	const r9, 0
	lt r9, r8, r9
	branch r9, false, @if_6_end
	const r0, 45
	call printChar[r0]
	neg r8, r8
@if_6_end:
	move r0, r8
	call printUint[r0]
	const r0, 10
	call printChar[r0]

@main:
	; 21 pc
	; begin initialize global variables
	const r8, [string-0]
	; end initialize global variables
	move text, r8
	move r0, r8
	call printString[r0]
	call printLength[]
	const r9, 1
	cast r9(u8*), r9(i16)
	move r8, text
	move r0, r8
	add r0, r0, r9
	call printString[r0]
	move r8, text
	load r9, [r8]
	cast r0(i16), r9(u8)
	call printIntLf[r0]

@printLength:
	; 13 pc
	const r0, 0
	move r8, text
	; 16:2 for *ptr != 0
	jump @for_7
@for_7_body:
	inc r0
	cast r9(i16), r8(u8*)
	const r10, 1
	add r9, r9, r10
	cast r8(u8*), r9(i16)
@for_7:
	load r9, [r8]
	const r10, 0
	notequals r9, r9, r10
	branch r9, true, @for_7_body
	call printIntLf[r0]

@printChar:
	ld   r0, SPH
	ld   r1, SPL
	add  r1, 3
	adc  r0, 0
	ldc  r1, @rr0
	ld   %15, r1
	jp   %0818

Global variables
	0: text (u8*/8)

String literals
	string lit 0 "hello world\n\0"
