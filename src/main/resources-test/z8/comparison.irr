@printString:
 Local variables
	arg 0: str (u8*/2)
	; 8 pc
	move r8, r0
	; 2:2 while true
	jump @while_1
@if_2_end:
	move r0, r10
	call printChar[r0]
@while_1:
	load r10, [r8]
	; 4:3 if chr == 0
	equals r0, r10, 0
	branch r0, false, @if_2_end

@printStringLength:
 Local variables
	arg 0: str (u8*/2)
	arg 1: length (u8/1)
	; 9 pc
	move r8, r0
	move r10, r2
	; 13:2 while length > 0
	jump @while_3
@while_3_body:
	load r0, [r8]
	call printChar[r0]
	dec r10
@while_3:
	gt r0, r10, 0
	branch r0, true, @while_3_body

@printUint:
 Local variables
	arg 0: number (i16/2)
	var 1: buffer[] (u8*/20)
	var 2: remainder (i64/8)
	; 26 pc
	const r8, 20
	; 24:2 while true
@while_4:
	dec r8
	const r9, 10
	move r11, r0
	mod r11, r11, r9
	cast remainder(i64), r11(i16)
	const r9, 10
	div r0, r0, r9
	cast r9(u8), remainder(i64)
	const r10, 48
	add r9, r9, r10
	cast r10(i16), r8(u8)
	cast r10(u8*), r10(i16)
	addrof r12, [buffer]
	add r12, r12, r10
	store [r12], r9
	; 30:3 if number == 0
	equals r9, r0, 0
	branch r9, false, @while_4
	cast r9(i16), r8(u8)
	cast r9(u8*), r9(i16)
	addrof r0, [buffer]
	add r0, r0, r9
	const r9, 20
	move r2, r9
	sub r2, r2, r8
	call printStringLength[r0, r2]

@printIntLf:
 Local variables
	arg 0: number (i16/2)
	; 8 pc
	move r8, r0
	; 38:2 if number < 0
	lt r10, r8, 0
	branch r10, false, @if_6_end
	const r0, 45
	call printChar[r0]
	neg r8, r8
@if_6_end:
	move r0, r8
	call printUint[r0]
	const r0, 10
	call printChar[r0]

@main:
	; 80 pc
	; begin initialize global variables
	; end initialize global variables
	const r0, [string-0]
	call printString[r0]
	const r8, 1
	const r10, 2
	lt r12, r8, r10
	cast r0(i16), r12(bool)
	call printIntLf[r0]
	lt r12, r10, r8
	cast r0(i16), r12(bool)
	call printIntLf[r0]
	const r0, [string-1]
	call printString[r0]
	const r12, 0
	const r13, 128
	lt r14, r12, r13
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	lt r14, r13, r12
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	const r0, [string-2]
	call printString[r0]
	lteq r14, r8, r10
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	lteq r14, r10, r8
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	const r0, [string-3]
	call printString[r0]
	lteq r14, r12, r13
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	lteq r14, r13, r12
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	const r0, [string-4]
	call printString[r0]
	equals r14, r8, r10
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	equals r14, r10, r8
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	const r0, [string-5]
	call printString[r0]
	notequals r14, r8, r10
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	notequals r14, r10, r8
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	const r0, [string-6]
	call printString[r0]
	gteq r14, r8, r10
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	gteq r14, r10, r8
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	const r0, [string-7]
	call printString[r0]
	gteq r14, r12, r13
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	gteq r14, r13, r12
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	const r0, [string-8]
	call printString[r0]
	gt r14, r8, r10
	cast r0(i16), r14(bool)
	call printIntLf[r0]
	gt r8, r10, r8
	cast r0(i16), r8(bool)
	call printIntLf[r0]
	const r0, [string-9]
	call printString[r0]
	gt r8, r12, r13
	cast r0(i16), r8(bool)
	call printIntLf[r0]
	gt r8, r13, r12
	cast r0(i16), r8(bool)
	call printIntLf[r0]

@printChar:
	ld   r0, SPH
	ld   r1, SPL
	add  r1, 3
	adc  r0, 0
	ldc  r1, @rr0
	ld   %15, r1
	jp   %0818

String literals
	string lit 0 "< (signed)\n\0"
	string lit 1 "< (unsigned)\n\0"
	string lit 2 "<= (signed)\n\0"
	string lit 3 "<= (unsigned)\n\0"
	string lit 4 "==\n\0"
	string lit 5 "!=\n\0"
	string lit 6 ">= (signed)\n\0"
	string lit 7 ">= (unsigned)\n\0"
	string lit 8 "> (signed)\n\0"
	string lit 9 "> (unsigned)\n\0"
