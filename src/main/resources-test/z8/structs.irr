@printStringLength:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 9 pc
	move r8, r0
	move r9, r2
	; 13:2 while length > 0
	jump @while_1
@while_1_body:
	load r0, [r8]
	call printChar[r0]
	dec r9
@while_1:
	const r0, 0
	gt r0, r9, r0
	branch r0, true, @while_1_body

@printUint:
 Local variables
	arg 0: number (i16/2)
	var 1: buffer[] (u8*/20)
	; 22 pc
	const r8, 20
	; 24:2 while true
@while_2:
	dec r8
	const r9, 10
	move r10, r0
	mod r10, r10, r9
	cast r9(i64), r10(i16)
	const r10, 10
	div r0, r0, r10
	cast r9(u8), r9(i64)
	const r10, 48
	add r9, r9, r10
	cast r10(i16), r8(u8)
	cast r10(u8*), r10(i16)
	addrof r11, [buffer]
	add r11, r11, r10
	store [r11], r9
	; 30:3 if number == 0
	const r9, 0
	equals r9, r0, r9
	branch r9, false, @while_2
	cast r9(i16), r8(u8)
	cast r9(u8*), r9(i16)
	addrof r0, [buffer]
	add r0, r0, r9
	const r9, 20
	move r2, r9
	sub r2, r2, r8
	call printStringLength[r0, r2]

@printIntLf:
 Local variables
	arg 0: number (i16/2)
	; 8 pc
	move r8, r0
	; 38:2 if number < 0
	const r9, 0
	lt r9, r8, r9
	branch r9, false, @if_4_end
	const r0, 45
	call printChar[r0]
	neg r8, r8
@if_4_end:
	move r0, r8
	call printUint[r0]
	const r0, 10
	call printChar[r0]

@main:
 Local variables
	var 0: pos (u8/2)
	; 39 pc
	; begin initialize global variables
	; end initialize global variables
	const r9, 1
	; 9:6 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=9:2].x
	addrof r10, pos
	store [r10], r9
	; 10:14 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=10:10].x
	addrof r9, pos
	load r9, [r9]
	const r10, 1
	add r9, r9, r10
	; 10:6 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=10:2].y
	addrof r10, pos
	inc r10
	store [r10], r9
	; 11:17 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=11:13].x
	addrof r9, pos
	load r9, [r9]
	cast r0(i16), r9(u8)
	call printIntLf[r0]
	; 12:17 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=12:13].y
	addrof r9, pos
	inc r9
	load r9, [r9]
	cast r0(i16), r9(u8)
	call printIntLf[r0]
	; 13:15 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=13:11].x
	addrof r8, pos
	load r8, [r8]
	cast r0(i16), r8(u8)
	call printIntLf[r0]

@printChar:
	ld   r0, SPH
	ld   r1, SPL
	add  r1, 3
	adc  r0, 0
	ldc  r1, @rr0
	ld   %15, r1
	jp   %0818

