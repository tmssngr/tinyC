@printStringLength:
 Local variables
	arg 0: str (u8*/2)
	arg 1: length (u8/1)
	var 2: chr (u8/1)
	var 3: t.3 (bool/1)
	; 23 pc
	; 13:2 while length > 0
@while_1:
	gt t.3, length, 0
	branch t.3, false, @while_1_break
	load chr, [str]
	call printChar[chr]
	dec length
	jump @while_1
@while_1_break:
@printStringLength_ret:

@printUint:
 Local variables
	arg 0: number (i16/2)
	var 1: buffer[] (u8*/20)
	var 2: pos (u8/1)
	var 3: remainder (i64/8)
	var 4: digit (u8/1)
	var 5: t.5 (i16/2)
	var 6: t.6 (i16/2)
	var 7: t.7 (i16/2)
	var 8: t.8 (u8/1)
	var 9: t.9 (u8/1)
	var 10: t.10 (u8*/2)
	var 11: t.11 (i16/2)
	var 12: t.12 (u8*/2)
	var 13: t.13 (bool/1)
	var 14: t.14 (u8*/2)
	var 15: t.15 (i16/2)
	var 16: t.16 (u8*/2)
	var 17: t.17 (u8/1)
	var 18: t.18 (u8/1)
	; 129 pc
	const pos, 20
	; 24:2 while true
@while_2:
	dec pos
	const t.6, 10
	move t.5, number
	mod t.5, t.5, t.6
	cast remainder(i64), t.5(i16)
	const t.7, 10
	div number, number, t.7
	cast t.8(u8), remainder(i64)
	const t.9, 48
	move digit, t.8
	add digit, digit, t.9
	cast t.11(i16), pos(u8)
	cast t.12(u8*), t.11(i16)
	addrof t.10, [buffer]
	add t.10, t.10, t.12
	store [t.10], digit
	; 30:3 if number == 0
	equals t.13, number, 0
	branch t.13, false, @if_3_end
	jump @while_2_break
@if_3_end:
	jump @while_2
@while_2_break:
	cast t.15(i16), pos(u8)
	cast t.16(u8*), t.15(i16)
	addrof t.14, [buffer]
	add t.14, t.14, t.16
	const t.18, 20
	move t.17, t.18
	sub t.17, t.17, pos
	call printStringLength[t.14, t.17]
@printUint_ret:

@printIntLf:
 Local variables
	arg 0: number (i16/2)
	var 1: t.1 (bool/1)
	var 2: t.2 (u8/1)
	var 3: t.3 (u8/1)
	; 26 pc
	; 38:2 if number < 0
	lt t.1, number, 0
	branch t.1, false, @if_4_end
	const t.2, 45
	call printChar[t.2]
	neg number, number
@if_4_end:
	call printUint[number]
	const t.3, 10
	call printChar[t.3]
@printIntLf_ret:

@main:
 Local variables
	var 0: pos (u8/2)
	var 1: x (u8*/2)
	var 2: t.2 (u8/1)
	var 3: t.3 (u8*/2)
	var 4: t.4 (u8/1)
	var 5: t.5 (u8/1)
	var 6: t.6 (u8*/2)
	var 7: t.7 (u8/1)
	var 8: t.8 (u8*/2)
	var 9: t.9 (i16/2)
	var 10: t.10 (u8/1)
	var 11: t.11 (u8*/2)
	var 12: t.12 (i16/2)
	var 13: t.13 (u8/1)
	var 14: t.14 (u8*/2)
	var 15: t.15 (i16/2)
	var 16: t.16 (u8/1)
	; 116 pc
	; begin initialize global variables
	; end initialize global variables
	const t.2, 1
	; 9:6 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=9:2].x
	addrof t.3, pos
	store [t.3], t.2
	; 10:14 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=10:10].x
	addrof t.6, pos
	load t.5, [t.6]
	const t.7, 1
	move t.4, t.5
	add t.4, t.4, t.7
	; 10:6 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=10:2].y
	addrof t.8, pos
	inc t.8
	store [t.8], t.4
	; 11:17 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=11:13].x
	addrof t.11, pos
	load t.10, [t.11]
	cast t.9(i16), t.10(u8)
	call printIntLf[t.9]
	; 12:17 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=12:13].y
	addrof t.14, pos
	inc t.14
	load t.13, [t.14]
	cast t.12(i16), t.13(u8)
	call printIntLf[t.12]
	; 13:15 ExprVarAccess[varName=pos, index=0, scope=function, type=Pos, varIsArray=false, location=13:11].x
	addrof x, pos
	load t.16, [x]
	cast t.15(i16), t.16(u8)
	call printIntLf[t.15]
@main_ret:

@printChar:
	ld   r0, SPH
	ld   r1, SPL
	add  r1, 3
	adc  r0, 0
	ldc  r1, @rr0
	ld   %15, r1
	jp   %0818

