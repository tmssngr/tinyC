@printString:
 Local variables
	arg 0: str (u8*/2)
	var 1: chr (u8/1)
	var 2: t.2 (bool/1)
	; 19 pc
	; 2:2 while true
@while_1:
	load chr, [str]
	; 4:3 if chr == 0
	equals t.2, chr, 0
	branch t.2, false, @if_2_end
	jump @while_1_break
@if_2_end:
	call printChar[chr]
	jump @while_1
@while_1_break:
@printString_ret:

