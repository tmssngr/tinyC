@for_3:
	lt t.2, i, 30
	branch t.2, false, @for_3_break
	; 12:3 if [...] == 0
	cast t.6(i16), i(u8)
	cast t.7(u8*), t.6(i16)
	addrof t.5, [board]
	add t.5, t.5, t.7
	load t.4, [t.5]
	equals t.3, t.4, 0
	branch t.3, false, @if_4_else
	const t.8, 32
	call printChar[t.8]
	jump @if_4_end
@if_4_else:
	const t.9, 42
	call printChar[t.9]
@if_4_end:
@for_3_continue:
	inc i
	jump @for_3
@for_3_break:
	const t.10, [string-0]
	call printString[t.10]
@printBoard_ret:

