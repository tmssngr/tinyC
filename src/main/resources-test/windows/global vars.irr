@printChar:
 Local variables
	arg 0: chr (u8/1)
	; 8 pc
	addrof r6, chr
	const r2, 1
	move chr, r1
	move r1, r6
	call printStringLength[r1, r2]

@printUint:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 25 pc
	const r6, 20
	; 13:2 while true
@while_1:
	dec r6
	const r7, 10
	move r3, r1
	move r0, r3
	mod r2, r0, r7
	move r3, r2
	const r7, 10
	move r0, r1
	div r0, r0, r7
	move r1, r0
	cast r7(u8), r3(i64)
	const r0, 48
	add r7, r7, r0
	cast r0(i64), r6(u8)
	cast r0(u8*), r0(i64)
	addrof r3, [buffer]
	add r3, r3, r0
	store [r3], r7
	; 19:3 if number == 0
	equals r7, r1, 0
	branch r7, false, @while_1
	cast r7(i64), r6(u8)
	cast r7(u8*), r7(i64)
	addrof r1, [buffer]
	add r1, r1, r7
	const r7, 20
	sub r7, r7, r6
	cast r2(i64), r7(u8)
	call printStringLength[r1, r2]

@printIntLf:
 Local variables
	arg 0: number (i64/8)
	; 8 pc
	move r6, r1
	; 27:2 if number < 0
	lt r7, r6, 0
	branch r7, false, @if_3_end
	const r1, 45
	call printChar[r1]
	neg r6, r6
@if_3_end:
	move r1, r6
	call printUint[r1]
	const r1, 10
	call printChar[r1]

@main:
	; 28 pc
	; begin initialize global variables
	const r6, 32
	const r7, 63
	addrof r0, space
	; end initialize global variables
	cast r1(i64), r7(i16)
	move space, r6
	move next, r7
	move ptrToSpace, r0
	call printIntLf[r1]
	move r6, ptrToSpace
	cast r7(i64), r6(i16*)
	const r0, 2
	move r6, r7
	add r6, r6, r0
	cast r6(i16*), r6(i64)
	move ptrToSpace, r6
	load r6, [r6]
	cast r1(i64), r6(i16)
	call printIntLf[r1]

@printStringLength:
	mov     rdi, rsp
	
	mov     r8, rdx
	mov     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

Global variables
	0: space (i16/2)
	1: next (i16/2)
	2: ptrToSpace (i16*/8)

