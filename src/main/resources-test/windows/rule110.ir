	; 37:2 for *str != 0
@for_1:
	load t.3, [str]
	notequals t.2, t.3, 0
	branch t.2, false, @for_1_break
	inc length
@for_1_continue:
	cast t.5(i64), str(u8*)
	const t.6, 1
	move t.4, t.5
	add t.4, t.4, t.6
	cast str(u8*), t.4(i64)
	jump @for_1
@for_1_break:
	; 40:9 return length
	ret length
	jump @strlen_ret
@strlen_ret:

