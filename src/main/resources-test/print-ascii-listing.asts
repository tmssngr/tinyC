i32 __random__;

void printString@@u8(u8* str) {
	i64 length;

	length = strlen@@u8(str);
	printStringLength@@u8@i64(str, length);
}

void printChar@u8(u8 chr) {
	printStringLength@@u8@u8(&chr, 1);
}

i64 strlen@@u8(u8* str) {
	i64 length;

	length = 0;
	for (; (*str) != 0; str = (u8*)(((i64)str) + 1)) {
		length = length + 1;
	}
	return length;
}

void printStringLength@@u8@u8(u8* str, u8 length) {
	printStringLength@@u8@i64(str, (i64)length);
}

void printStringLength@@u8@i64(u8* str, i64 length) {
}

void printNibble@u8(u8 x) {
	x = x & 15;
	if (x > 9) {
		x = x + 7;
	}
	x = x + 48;
	printChar@u8(x);
}

void printHex2@u8(u8 x) {
	printNibble@u8(x >> 4);
	printNibble@u8(x);
}

void main() {
	u8 i;
	u8 i;

	printString@@u8(" x");
	i = 0;
	for (; i < 16; i = i + 1) {
		if ((i & 7) == 0) {
			printChar@u8(32);
		}
		printNibble@u8(i);
	}
	printChar@u8(10);
	i = 32;
	for (; i < 128; i = i + 1) {
		if ((i & 15) == 0) {
			printHex2@u8(i);
		}
		if ((i & 7) == 0) {
			printChar@u8(32);
		}
		printChar@u8(i);
		if ((i & 15) == 15) {
			printChar@u8(10);
		}
	}
}
