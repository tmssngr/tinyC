@printChar:
 Local variables
	arg 0: chr (u8/1)
	; 8 pc
	addrof r8, chr
	const r2, 1
	move chr, r1
	move r1, r8
	call printStringLength[r1, r2]

@printUint:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 25 pc
	const r8, 20
	; 13:2 while true
@while_1:
	dec r8
	const r9, 10
	move r4, r1
	move r0, r4
	mod r3, r0, r9
	move r4, r3
	const r9, 10
	move r0, r1
	div r0, r0, r9
	move r1, r0
	cast r9(u8), r4(i64)
	const r0, 48
	add r9, r9, r0
	cast r0(i64), r8(u8)
	cast r0(u8*), r0(i64)
	addrof r3, [buffer]
	add r3, r3, r0
	store [r3], r9
	; 19:3 if number == 0
	equals r9, r1, 0
	branch r9, false, @while_1
	cast r9(i64), r8(u8)
	cast r9(u8*), r9(i64)
	addrof r1, [buffer]
	add r1, r1, r9
	const r9, 20
	sub r9, r9, r8
	cast r2(i64), r9(u8)
	call printStringLength[r1, r2]

@printIntLf:
 Local variables
	arg 0: number (i64/8)
	; 8 pc
	move r8, r1
	; 27:2 if number < 0
	lt r9, r8, 0
	branch r9, false, @if_3_end
	const r1, 45
	call printChar[r1]
	neg r8, r8
@if_3_end:
	move r1, r8
	call printUint[r1]
	const r1, 10
	call printChar[r1]

@initRandom:
 Local variables
	arg 0: salt (i32/4)
	; 4 pc
	move r0, r1
	move __random__, r0

@random:
	; 23 pc
	move r0, __random__
	move r1, r0
	const r2, 524287
	move r3, r1
	and r3, r3, r2
	const r2, 48271
	mul r3, r3, r2
	const r4, 15
	shiftright r1, r1, r4
	const r2, 48271
	mul r1, r1, r2
	const r2, 65535
	move r5, r1
	and r5, r5, r2
	const r4, 15
	move r2, r5
	shiftleft r2, r2, r4
	const r4, 16
	shiftright r1, r1, r4
	add r1, r1, r3
	add r1, r1, r2
	const r2, 2147483647
	move r0, r1
	and r0, r0, r2
	const r4, 31
	shiftright r1, r1, r4
	add r0, r0, r1
	; 118:9 return __random__
	move __random__, r0

@randomU8:
	; 2 pc
	; 122:10 return (u8)
	call r0 = random[] -> i32
	cast r0(u8), r0(i32)

@main:
	; 11 pc
	; begin initialize global variables
	const r8, 0
	; end initialize global variables
	const r1, 7439742
	move __random__, r8
	call initRandom[r1]
	const r8, 0
	; 5:2 for i < 50
	jump @for_4
@for_4_body:
	call r0 = randomU8[] -> u8
	cast r1(i64), r0(u8)
	call printIntLf[r1]
	inc r8
@for_4:
	lt r0, r8, 50
	branch r0, true, @for_4_body

@printStringLength:
	mov rdx, rsi
	mov rsi, rdi
	mov rdi, 1
	mov rax, 1
	syscall
	ret

Global variables
	0: __random__ (i32/4)

