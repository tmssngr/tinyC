@printChar:
 Local variables
	arg 0: chr (u8/1)
	; 8 pc
	addrof r8, chr
	const r2, 1
	move chr, r1
	move r1, r8
	call printStringLength[r1, r2]

@printUint:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 25 pc
	const r8, 20
	; 13:2 while true
@while_1:
	dec r8
	const r9, 10
	move r4, r1
	move r0, r4
	mod r3, r0, r9
	move r4, r3
	const r9, 10
	move r0, r1
	div r0, r0, r9
	move r1, r0
	cast r9(u8), r4(i64)
	const r0, 48
	add r9, r9, r0
	cast r0(i64), r8(u8)
	cast r0(u8*), r0(i64)
	addrof r3, [buffer]
	add r3, r3, r0
	store [r3], r9
	; 19:3 if number == 0
	equals r9, r1, 0
	branch r9, false, @while_1
	cast r9(i64), r8(u8)
	cast r9(u8*), r9(i64)
	addrof r1, [buffer]
	add r1, r1, r9
	const r9, 20
	sub r9, r9, r8
	cast r2(i64), r9(u8)
	call printStringLength[r1, r2]

@unusedArgs:
 Local variables
	arg 0: a (i16/2)
	arg 1: b (bool/1)
	arg 2: c (i64/8)
	arg 3: d (i64/8)
	; 1 pc
	; 9:9 return c
	move r0, r3

@main:
	; 38 pc
	; begin initialize global variables
	const r8, 48
	const r9, 49
	const r0, 50
	const r5, 34
	; end initialize global variables
	const r1, 1
	const r2, 1
	const r3, 2
	const r4, 3
	move zero, r8
	move one, r9
	move two, r0
	move threeFour, r5
	call _ = unusedArgs[r1, r2, r3, r4] -> i64
	move r8, zero
	move r1, r8
	call printChar[r1]
	addrof r8, one
	load r1, [r8]
	call printChar[r1]
	addrof r8, two
	const r9, 0
	cast r9(u8*), r9(i64)
	add r8, r8, r9
	load r1, [r8]
	call printChar[r1]
	move r8, threeFour
	cast r1(i64), r8(u8)
	call printUint[r1]
	const r1, 10
	call printChar[r1]

@printStringLength:
	mov rdx, rsi
	mov rsi, rdi
	mov rdi, 1
	mov rax, 1
	syscall
	ret

Global variables
	0: zero (u8/1)
	1: one (u8/1)
	2: two (u8/1)
	3: threeFour (u8/1)

