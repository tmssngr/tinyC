@printString:
 Local variables
	arg 0: str (u8*/8)
	; 6 pc
	move r8, r1
	move r1, r8
	call r0 = strlen[r1] -> i64
	move r1, r8
	move r2, r0
	call printStringLength[r1, r2]

@printChar:
 Local variables
	arg 0: chr (u8/1)
	; 8 pc
	addrof r8, chr
	const r2, 1
	move chr, r1
	move r1, r8
	call printStringLength[r1, r2]

@printUint:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 25 pc
	const r8, 20
	; 13:2 while true
@while_1:
	dec r8
	const r9, 10
	move r4, r1
	move r0, r4
	mod r3, r0, r9
	move r4, r3
	const r9, 10
	move r0, r1
	div r0, r0, r9
	move r1, r0
	cast r9(u8), r4(i64)
	const r0, 48
	add r9, r9, r0
	cast r0(i64), r8(u8)
	cast r0(u8*), r0(i64)
	addrof r3, [buffer]
	add r3, r3, r0
	store [r3], r9
	; 19:3 if number == 0
	equals r9, r1, 0
	branch r9, false, @while_1
	cast r9(i64), r8(u8)
	cast r9(u8*), r9(i64)
	addrof r1, [buffer]
	add r1, r1, r9
	const r9, 20
	sub r9, r9, r8
	cast r2(i64), r9(u8)
	call printStringLength[r1, r2]

@printIntLf:
 Local variables
	arg 0: number (i64/8)
	; 8 pc
	move r8, r1
	; 27:2 if number < 0
	lt r9, r8, 0
	branch r9, false, @if_3_end
	const r1, 45
	call printChar[r1]
	neg r8, r8
@if_3_end:
	move r1, r8
	call printUint[r1]
	const r1, 10
	call printChar[r1]

@strlen:
 Local variables
	arg 0: str (u8*/8)
	; 10 pc
	const r0, 0
	; 37:2 for *str != 0
	jump @for_4
@for_4_body:
	inc r0
	cast r2(i64), r1(u8*)
	const r3, 1
	move r1, r2
	add r1, r1, r3
	cast r1(u8*), r1(i64)
@for_4:
	load r2, [r1]
	notequals r2, r2, 0
	branch r2, true, @for_4_body
	; 40:9 return length

@main:
 Local variables
	var 0: c (i16/2)
	var 1: d (i16/2)
	var 2: t (bool/1)
	var 3: f (bool/1)
	var 4: b1 (u8/1)
	; 220 pc
	; begin initialize global variables
	; end initialize global variables
	const r1, [string-0]
	call printString[r1]
	const r8, 0
	const r9, 1
	const r0, 2
	move c, r0
	const r0, 3
	move d, r0
	const r0, 1
	move t, r0
	const r0, 0
	move f, r0
	move r0, r8
	and r0, r0, r8
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r8
	and r0, r0, r9
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r9
	and r0, r0, r8
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r9
	and r0, r0, r9
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	const r1, [string-1]
	call printString[r1]
	move r0, r8
	or r0, r0, r8
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r8
	or r0, r0, r9
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r9
	or r0, r0, r8
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r9
	or r0, r0, r9
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	const r1, [string-2]
	call printString[r1]
	move r0, r8
	xor r0, r0, r8
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r8
	move r2, c
	xor r0, r0, r2
	move c, r2
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r0, r9
	xor r0, r0, r8
	cast r1(i64), r0(i16)
	call printIntLf[r1]
	move r8, r9
	move r0, c
	xor r8, r8, r0
	move c, r0
	cast r1(i64), r8(i16)
	call printIntLf[r1]
	const r1, [string-3]
	call printString[r1]
	; 26:15 logic and
	move r8, f
	move r0, r8
	branch r0, false, @and_next_5
	move r0, r8
@and_next_5:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	; 27:15 logic and
	move r0, r8
	branch r0, false, @and_next_6
	move r0, t
	move t, r0
@and_next_6:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	; 28:15 logic and
	move r0, t
	move r2, r0
	move t, r0
	branch r2, false, @and_next_7
	move r2, r8
@and_next_7:
	cast r1(i64), r2(bool)
	call printIntLf[r1]
	; 29:15 logic and
	move r0, t
	move r2, r0
	branch r2, true, @and_2nd_8
	move t, r0
	jump @and_next_8
@and_2nd_8:
	move r2, r0
	move t, r0
@and_next_8:
	cast r1(i64), r2(bool)
	call printIntLf[r1]
	const r1, [string-4]
	call printString[r1]
	; 31:15 logic or
	move r0, r8
	branch r0, true, @or_next_9
	move r0, r8
@or_next_9:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	; 32:15 logic or
	move r0, r8
	branch r0, true, @or_next_10
	move r0, t
	move t, r0
@or_next_10:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	; 33:15 logic or
	move r0, t
	move r2, r0
	move t, r0
	branch r2, true, @or_next_11
	move r2, r8
@or_next_11:
	cast r1(i64), r2(bool)
	call printIntLf[r1]
	; 34:15 logic or
	move r0, t
	move r2, r0
	branch r2, false, @or_2nd_12
	move t, r0
	jump @or_next_12
@or_2nd_12:
	move r2, r0
	move t, r0
@or_next_12:
	cast r1(i64), r2(bool)
	call printIntLf[r1]
	const r1, [string-5]
	call printString[r1]
	notlog r8, r8
	cast r1(i64), r8(bool)
	call printIntLf[r1]
	move r8, t
	notlog r8, r8
	cast r1(i64), r8(bool)
	call printIntLf[r1]
	const r1, [string-6]
	call printString[r1]
	const r8, 10
	const r0, 6
	const r2, 1
	and r8, r8, r0
	or r8, r8, r2
	move b1, r2
	cast r1(i64), r8(u8)
	call printIntLf[r1]
	; 43:20 logic or
	move r8, c
	equals r0, r9, r8
	branch r0, true, @or_next_13
	move r0, d
	lt r0, r8, r0
	move d, r0
@or_next_13:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	; 44:20 logic and
	equals r0, r9, r8
	branch r0, false, @and_next_14
	move r0, d
	lt r0, r8, r0
@and_next_14:
	cast r1(i64), r0(bool)
	call printIntLf[r1]
	const r8, -1
	cast r1(i64), r8(i16)
	call printIntLf[r1]
	neg r8, r9
	cast r1(i64), r8(i16)
	call printIntLf[r1]
	move r8, b1
	not r8, r8
	cast r1(i64), r8(u8)
	call printIntLf[r1]

@printStringLength:
	mov rdx, rsi
	mov rsi, rdi
	mov rdi, 1
	mov rax, 1
	syscall
	ret

String literals
	string lit 0 "Bit-&:\n\0"
	string lit 1 "\nBit-|:\n\0"
	string lit 2 "\nBit-^:\n\0"
	string lit 3 "\nLogic-&&:\n\0"
	string lit 4 "\nLogic-||:\n\0"
	string lit 5 "\nLogic-!:\n\0"
	string lit 6 "\nmisc:\n\0"
