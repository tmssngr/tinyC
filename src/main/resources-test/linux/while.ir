@printChar:
 Local variables
	arg 0: chr (u8/1)
	var 1: t.1 (u8*/8)
	var 2: t.2 (i64/8)
	; 12 pc
	addrof t.1, chr
	const t.2, 1
	call printStringLength[t.1, t.2]
@printChar_ret:

@printUint:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	var 2: pos (u8/1)
	var 3: remainder (i64/8)
	var 4: digit (u8/1)
	var 5: t.5 (i64/8)
	var 6: t.6 (i64/8)
	var 7: t.7 (u8/1)
	var 8: t.8 (u8/1)
	var 9: t.9 (u8*/8)
	var 10: t.10 (i64/8)
	var 11: t.11 (u8*/8)
	var 12: t.12 (bool/1)
	var 13: t.13 (u8*/8)
	var 14: t.14 (i64/8)
	var 15: t.15 (u8*/8)
	var 16: t.16 (i64/8)
	var 17: t.17 (u8/1)
	var 18: t.18 (u8/1)
	; 129 pc
	const pos, 20
	; 13:2 while true
@while_1:
	dec pos
	const t.5, 10
	move remainder, number
	mod remainder, remainder, t.5
	const t.6, 10
	div number, number, t.6
	cast t.7(u8), remainder(i64)
	const t.8, 48
	move digit, t.7
	add digit, digit, t.8
	cast t.10(i64), pos(u8)
	cast t.11(u8*), t.10(i64)
	addrof t.9, [buffer]
	add t.9, t.9, t.11
	store [t.9], digit
	; 19:3 if number == 0
	equals t.12, number, 0
	branch t.12, false, @if_2_end
	jump @while_1_break
@if_2_end:
	jump @while_1
@while_1_break:
	cast t.14(i64), pos(u8)
	cast t.15(u8*), t.14(i64)
	addrof t.13, [buffer]
	add t.13, t.13, t.15
	const t.18, 20
	move t.17, t.18
	sub t.17, t.17, pos
	cast t.16(i64), t.17(u8)
	call printStringLength[t.13, t.16]
@printUint_ret:

@printIntLf:
 Local variables
	arg 0: number (i64/8)
	var 1: t.1 (bool/1)
	var 2: t.2 (u8/1)
	var 3: t.3 (u8/1)
	; 26 pc
	; 27:2 if number < 0
	lt t.1, number, 0
	branch t.1, false, @if_3_end
	const t.2, 45
	call printChar[t.2]
	neg number, number
@if_3_end:
	call printUint[number]
	const t.3, 10
	call printChar[t.3]
@printIntLf_ret:

@main:
 Local variables
	var 0: i (u8/1)
	var 1: t.1 (bool/1)
	var 2: t.2 (i64/8)
	var 3: t.3 (i64/8)
	var 4: t.4 (bool/1)
	; 50 pc
	; begin initialize global variables
	; end initialize global variables
	const i, 5
	; 5:2 while i > 0
@while_4:
	gt t.1, i, 0
	branch t.1, false, @while_4_break
	cast t.2(i64), i(u8)
	call printIntLf[t.2]
	dec i
	jump @while_4
@while_4_break:
	; 10:2 while true
@while_5:
	cast t.3(i64), i(u8)
	call printIntLf[t.3]
	inc i
	; 13:3 if i < 5
	lt t.4, i, 5
	branch t.4, false, @if_6_end
	jump @while_5
@if_6_end:
	jump @while_5_break
	jump @while_5
@while_5_break:
	; 19:2 while true
@while_7:
	; 20:3 return
	jump @main_ret
	jump @while_7
@while_7_break:
@main_ret:

@printStringLength:
	mov rdx, rsi
	mov rsi, rdi
	mov rdi, 1
	mov rax, 1
	syscall
	ret

