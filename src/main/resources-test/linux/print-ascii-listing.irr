@printString:
 Local variables
	arg 0: str (u8*/8)
	; 6 pc
	move r8, r1
	move r1, r8
	call r0 = strlen[r1] -> i64
	move r1, r8
	move r2, r0
	call printStringLength[r1, r2]

@printChar:
 Local variables
	arg 0: chr (u8/1)
	; 8 pc
	addrof r8, chr
	const r2, 1
	move chr, r1
	move r1, r8
	call printStringLength[r1, r2]

@strlen:
 Local variables
	arg 0: str (u8*/8)
	; 10 pc
	const r0, 0
	; 37:2 for *str != 0
	jump @for_1
@for_1_body:
	inc r0
	cast r2(i64), r1(u8*)
	const r3, 1
	move r1, r2
	add r1, r1, r3
	cast r1(u8*), r1(i64)
@for_1:
	load r2, [r1]
	notequals r2, r2, 0
	branch r2, true, @for_1_body
	; 40:9 return length

@printNibble:
 Local variables
	arg 0: x (u8/1)
	; 6 pc
	const r8, 15
	and r1, r1, r8
	; 5:2 if x > 9
	gt r8, r1, 9
	branch r8, false, @if_2_end
	add r1, 7
@if_2_end:
	add r1, 48
	call printChar[r1]

@printHex2:
 Local variables
	arg 0: x (u8/1)
	; 6 pc
	move r8, r1
	const r4, 4
	move r1, r8
	shiftright r1, r1, r4
	call printNibble[r1]
	move r1, r8
	call printNibble[r1]

@main:
	; 36 pc
	; begin initialize global variables
	; end initialize global variables
	const r1, [string-0]
	call printString[r1]
	const r8, 0
	; 19:2 for i < 16
	jump @for_3
@for_3_body:
	; 20:3 if i & 7 == 0
	const r9, 7
	move r0, r8
	and r0, r0, r9
	equals r9, r0, 0
	branch r9, false, @if_4_end
	const r1, 32
	call printChar[r1]
@if_4_end:
	move r1, r8
	call printNibble[r1]
	inc r8
@for_3:
	lt r9, r8, 16
	branch r9, true, @for_3_body
	const r1, 10
	call printChar[r1]
	const r8, 32
	; 27:2 for i < 128
	jump @for_5
@for_5_body:
	; 28:3 if i & 15 == 0
	const r9, 15
	move r0, r8
	and r0, r0, r9
	equals r9, r0, 0
	branch r9, false, @if_6_end
	move r1, r8
	call printHex2[r1]
@if_6_end:
	; 31:3 if i & 7 == 0
	const r9, 7
	move r0, r8
	and r0, r0, r9
	equals r9, r0, 0
	branch r9, false, @if_7_end
	const r1, 32
	call printChar[r1]
@if_7_end:
	move r1, r8
	call printChar[r1]
	; 35:3 if i & 15 == 15
	const r9, 15
	move r0, r8
	and r0, r0, r9
	equals r9, r0, 15
	branch r9, false, @for_5_continue
	const r1, 10
	call printChar[r1]
@for_5_continue:
	inc r8
@for_5:
	lt r0, r8, 128
	branch r0, true, @for_5_body

@printStringLength:
	mov rdx, rsi
	mov rsi, rdi
	mov rdi, 1
	mov rax, 1
	syscall
	ret

String literals
	string lit 0 " x\0"
