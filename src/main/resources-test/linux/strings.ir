@printString:
 Local variables
	arg 0: str (u8*/8)
	var 1: length (i64/8)
	; 10 pc
	call length = strlen[str] -> i64
	call printStringLength[str, length]
@printString_ret:

@printChar:
 Local variables
	arg 0: chr (u8/1)
	var 1: t.1 (u8*/8)
	var 2: t.2 (i64/8)
	; 12 pc
	addrof t.1, chr
	const t.2, 1
	call printStringLength[t.1, t.2]
@printChar_ret:

@printUint:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	var 2: pos (u8/1)
	var 3: remainder (i64/8)
	var 4: digit (u8/1)
	var 5: t.5 (i64/8)
	var 6: t.6 (i64/8)
	var 7: t.7 (u8/1)
	var 8: t.8 (u8/1)
	var 9: t.9 (u8*/8)
	var 10: t.10 (i64/8)
	var 11: t.11 (u8*/8)
	var 12: t.12 (bool/1)
	var 13: t.13 (u8*/8)
	var 14: t.14 (i64/8)
	var 15: t.15 (u8*/8)
	var 16: t.16 (i64/8)
	var 17: t.17 (u8/1)
	var 18: t.18 (u8/1)
	; 129 pc
	const pos, 20
	; 13:2 while true
@while_1:
	dec pos
	const t.5, 10
	move remainder, number
	mod remainder, remainder, t.5
	const t.6, 10
	div number, number, t.6
	cast t.7(u8), remainder(i64)
	const t.8, 48
	move digit, t.7
	add digit, digit, t.8
	cast t.10(i64), pos(u8)
	cast t.11(u8*), t.10(i64)
	addrof t.9, [buffer]
	add t.9, t.9, t.11
	store [t.9], digit
	; 19:3 if number == 0
	equals t.12, number, 0
	branch t.12, false, @if_2_end
	jump @while_1_break
@if_2_end:
	jump @while_1
@while_1_break:
	cast t.14(i64), pos(u8)
	cast t.15(u8*), t.14(i64)
	addrof t.13, [buffer]
	add t.13, t.13, t.15
	const t.18, 20
	move t.17, t.18
	sub t.17, t.17, pos
	cast t.16(i64), t.17(u8)
	call printStringLength[t.13, t.16]
@printUint_ret:

@printIntLf:
 Local variables
	arg 0: number (i64/8)
	var 1: t.1 (bool/1)
	var 2: t.2 (u8/1)
	var 3: t.3 (u8/1)
	; 26 pc
	; 27:2 if number < 0
	lt t.1, number, 0
	branch t.1, false, @if_3_end
	const t.2, 45
	call printChar[t.2]
	neg number, number
@if_3_end:
	call printUint[number]
	const t.3, 10
	call printChar[t.3]
@printIntLf_ret:

@strlen:
 Local variables
	arg 0: str (u8*/8)
	var 1: length (i64/8)
	var 2: t.2 (bool/1)
	var 3: t.3 (u8/1)
	var 4: t.4 (i64/8)
	var 5: t.5 (i64/8)
	var 6: t.6 (i64/8)
	; 50 pc
	const length, 0
	; 37:2 for *str != 0
@for_4:
	load t.3, [str]
	notequals t.2, t.3, 0
	branch t.2, false, @for_4_break
	inc length
@for_4_continue:
	cast t.5(i64), str(u8*)
	const t.6, 1
	move t.4, t.5
	add t.4, t.4, t.6
	cast str(u8*), t.4(i64)
	jump @for_4
@for_4_break:
	; 40:9 return length
	ret length
	jump @strlen_ret
@strlen_ret:

@main:
 Local variables
	var 0: second (u8*/8)
	var 1: chr (u8/1)
	var 2: t.2 (i64/8)
	var 3: t.3 (u8*/8)
	var 4: t.4 (i64/8)
	; 43 pc
	; begin initialize global variables
	const text, [string-0]
	; end initialize global variables
	call printString[text]
	call printLength[]
	const t.2, 1
	cast t.3(u8*), t.2(i64)
	move second, text
	add second, second, t.3
	call printString[second]
	load chr, [text]
	cast t.4(i64), chr(u8)
	call printIntLf[t.4]
@main_ret:

@printLength:
 Local variables
	var 0: length (i16/2)
	var 1: ptr (u8*/8)
	var 2: t.2 (bool/1)
	var 3: t.3 (u8/1)
	var 4: t.4 (i64/8)
	var 5: t.5 (i64/8)
	var 6: t.6 (i64/8)
	var 7: t.7 (i64/8)
	; 59 pc
	const length, 0
	move ptr, text
	; 16:2 for *ptr != 0
@for_5:
	load t.3, [ptr]
	notequals t.2, t.3, 0
	branch t.2, false, @for_5_break
	inc length
@for_5_continue:
	cast t.5(i64), ptr(u8*)
	const t.6, 1
	move t.4, t.5
	add t.4, t.4, t.6
	cast ptr(u8*), t.4(i64)
	jump @for_5
@for_5_break:
	cast t.7(i64), length(i16)
	call printIntLf[t.7]
@printLength_ret:

@printStringLength:
	mov rdx, rsi
	mov rsi, rdi
	mov rdi, 1
	mov rax, 1
	syscall
	ret

Global variables
	0: text (u8*/8)

String literals
	string lit 0 "hello world\n\0"
