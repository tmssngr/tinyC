@printChar:
 Local variables
	arg 0: chr (u8/1)
	var 1: t.1 (u8*/8)
	var 2: t.2 (i64/8)
	; 12 pc
	addrof t.1, chr
	const t.2, 1
	call printStringLength[t.1, t.2]
@printChar_ret:

@printUint:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	var 2: pos (u8/1)
	var 3: remainder (i64/8)
	var 4: digit (u8/1)
	var 5: t.5 (i64/8)
	var 6: t.6 (i64/8)
	var 7: t.7 (u8/1)
	var 8: t.8 (u8/1)
	var 9: t.9 (u8*/8)
	var 10: t.10 (i64/8)
	var 11: t.11 (u8*/8)
	var 12: t.12 (bool/1)
	var 13: t.13 (u8*/8)
	var 14: t.14 (i64/8)
	var 15: t.15 (u8*/8)
	var 16: t.16 (i64/8)
	var 17: t.17 (u8/1)
	var 18: t.18 (u8/1)
	; 129 pc
	const pos, 20
	; 13:2 while true
@while_1:
	dec pos
	const t.5, 10
	move remainder, number
	mod remainder, remainder, t.5
	const t.6, 10
	div number, number, t.6
	cast t.7(u8), remainder(i64)
	const t.8, 48
	move digit, t.7
	add digit, digit, t.8
	cast t.10(i64), pos(u8)
	cast t.11(u8*), t.10(i64)
	addrof t.9, [buffer]
	add t.9, t.9, t.11
	store [t.9], digit
	; 19:3 if number == 0
	equals t.12, number, 0
	branch t.12, false, @if_2_end
	jump @while_1_break
@if_2_end:
	jump @while_1
@while_1_break:
	cast t.14(i64), pos(u8)
	cast t.15(u8*), t.14(i64)
	addrof t.13, [buffer]
	add t.13, t.13, t.15
	const t.18, 20
	move t.17, t.18
	sub t.17, t.17, pos
	cast t.16(i64), t.17(u8)
	call printStringLength[t.13, t.16]
@printUint_ret:

@printIntLf:
 Local variables
	arg 0: number (i64/8)
	var 1: t.1 (bool/1)
	var 2: t.2 (u8/1)
	var 3: t.3 (u8/1)
	; 26 pc
	; 27:2 if number < 0
	lt t.1, number, 0
	branch t.1, false, @if_3_end
	const t.2, 45
	call printChar[t.2]
	neg number, number
@if_3_end:
	call printUint[number]
	const t.3, 10
	call printChar[t.3]
@printIntLf_ret:

@main:
 Local variables
	var 0: foo (i16/2)
	var 1: bar (i16/2)
	var 2: bazz (i16/2)
	var 3: a (i16/2)
	var 4: b (i16/2)
	var 5: t.5 (u8/1)
	var 6: t.6 (i64/8)
	var 7: t.7 (i16/2)
	var 8: t.8 (u8/1)
	var 9: t.9 (i64/8)
	var 10: t.10 (i64/8)
	var 11: t.11 (i64/8)
	var 12: t.12 (i16/2)
	var 13: t.13 (i64/8)
	var 14: t.14 (i16/2)
	var 15: t.15 (i16/2)
	var 16: t.16 (i64/8)
	var 17: t.17 (i16/2)
	var 18: t.18 (i64/8)
	var 19: t.19 (i16/2)
	var 20: t.20 (i64/8)
	var 21: t.21 (i16/2)
	; 180 pc
	; begin initialize global variables
	; end initialize global variables
	const t.5, 22
	cast foo(i16), t.5(u8)
	move bar, foo
	mul bar, bar, foo
	const foo, 1
	move t.7, bar
	add t.7, t.7, foo
	cast t.6(i64), t.7(i16)
	call printIntLf[t.6]
	const t.8, 21
	cast foo(i16), t.8(u8)
	cast t.9(i64), foo(i16)
	call printIntLf[t.9]
	cast t.10(i64), bazz(i16)
	call printIntLf[t.10]
	const a, 1000
	const b, 10
	move t.12, a
	div t.12, t.12, b
	cast t.11(i64), t.12(i16)
	call printIntLf[t.11]
	const t.15, 255
	move t.14, a
	and t.14, t.14, t.15
	cast t.13(i64), t.14(i16)
	call printIntLf[t.13]
	const a, 10
	const b, 1
	move t.17, a
	shiftright t.17, t.17, b
	cast t.16(i64), t.17(i16)
	call printIntLf[t.16]
	const a, 9
	const b, 2
	move t.19, a
	shiftright t.19, t.19, b
	cast t.18(i64), t.19(i16)
	call printIntLf[t.18]
	const a, 1
	move t.21, a
	shiftleft t.21, t.21, b
	cast t.20(i64), t.21(i16)
	call printIntLf[t.20]
@main_ret:

@printStringLength:
	mov     rdi, rsp
	
	mov     r8, rdx
	mov     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

