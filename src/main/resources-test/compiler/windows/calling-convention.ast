i32 __random__;

void printChar@u8(u8 chr) {
	printStringLength@@u8@u8(&chr, 1);
}

void printUint@i64(i64 number) {
	u8* buffer[20];
	u8 pos;
	i64 remainder;
	u8 digit;

	pos = 20;
	while (true) {
		pos = pos - 1;
		remainder = number % 10;
		number = number / 10;
		digit = ((u8)remainder) + 48;
		buffer[(i64)pos] = digit;
		if (number == 0) {
			break;
		}
	}
	printStringLength@@u8@u8(&buffer[(i64)pos], 20 - pos);
}

void printIntLf@i16(i16 number) {
	printIntLf@i64((i64)number);
}

void printIntLf@i64(i64 number) {
	if (number < 0) {
		printChar@u8(45);
		number = -number;
	}
	printUint@i64(number);
	printChar@u8(10);
}

void printStringLength@@u8@u8(u8* str, u8 length) {
	printStringLength@@u8@i64(str, (i64)length);
}

void printStringLength@@u8@i64(u8* str, i64 length) {
}

i16 printAndSum@i16@i16@i16@i16@i16@i16@i16@i16(i16 a, i16 b, i16 c, i16 d, i16 e, i16 f, i16 g, i16 h) {
	printIntLf@i16(a);
	printIntLf@i16(b);
	printIntLf@i16(c);
	printIntLf@i16(d);
	printIntLf@i16(e);
	printIntLf@i16(f);
	printIntLf@i16(g);
	printIntLf@i16(h);
	return ((((((a + b) + c) + d) + e) + f) + g) + h;
}

void main() {
	i16 sum;

	sum = printAndSum@i16@i16@i16@i16@i16@i16@i16@i16(1, 2, 3, 4, 5, 6, 7, 8);
	printIntLf@i16(sum);
}
