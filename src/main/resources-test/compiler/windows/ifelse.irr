@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	var 1: t.1 (u8*/8)
	var 2: t.2 (u8/1)
	; 12 pc
	addrof t.1, chr
	const t.2, 1
	call printStringLength@@u8@u8[t.1, t.2]

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	var 2: pos (u8/1)
	var 3: remainder (i64/8)
	var 4: digit (u8/1)
	var 5: t.5 (i64/8)
	var 6: t.6 (i64/8)
	var 7: t.7 (u8/1)
	var 8: t.8 (u8/1)
	var 9: t.9 (u8*/8)
	var 10: t.10 (i64/8)
	var 11: t.11 (u8*/8)
	var 12: t.12 (bool/1)
	var 13: t.13 (i64/8)
	var 14: t.14 (u8*/8)
	var 15: t.15 (i64/8)
	var 16: t.16 (u8*/8)
	var 17: t.17 (u8/1)
	var 18: t.18 (u8/1)
	; 126 pc
	const pos, 20
	; 25:2 while true
@while_1:
	dec pos
	const t.5, 10
	move remainder, number
	mod remainder, remainder, t.5
	const t.6, 10
	div number, number, t.6
	cast t.7(u8), remainder(i64)
	const t.8, 48
	move digit, t.7
	add digit, digit, t.8
	cast t.10(i64), pos(u8)
	cast t.11(u8*), t.10(i64)
	addrof t.9, [buffer]
	add t.9, t.9, t.11
	store [t.9], digit
	; 31:3 if number == 0
	const t.13, 0
	equals t.12, number, t.13
	branch t.12, false, @while_1, @while_1_break
	cast t.15(i64), pos(u8)
	cast t.16(u8*), t.15(i64)
	addrof t.14, [buffer]
	add t.14, t.14, t.16
	const t.18, 20
	move t.17, t.18
	sub t.17, t.17, pos
	call printStringLength@@u8@u8[t.14, t.17]

@printIntLf@i16:
 Local variables
	arg 0: number (i16/2)
	var 1: t.1 (i64/8)
	; 8 pc
	cast t.1(i64), number(i16)
	call printIntLf@i64[t.1]

@printIntLf@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: t.1 (bool/1)
	var 2: t.2 (i64/8)
	var 3: t.3 (u8/1)
	var 4: t.4 (u8/1)
	; 30 pc
	; 51:2 if number < 0
	const t.2, 0
	lt t.1, number, t.2
	branch t.1, false, @if_3_end, @if_3_then
	const t.3, 45
	call printChar@u8[t.3]
	neg number, number
@if_3_end:
	call printUint@i64[number]
	const t.4, 10
	call printChar@u8[t.4]

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	var 2: t.2 (i64/8)
	; 10 pc
	cast t.2(i64), length(u8)
	call printStringLength@@u8@i64[str, t.2]

@main:
 Local variables
	var 0: a (i16/2)
	var 1: t.1 (bool/1)
	var 2: t.2 (i16/2)
	; 26 pc
	; begin initialize global variables
	; end initialize global variables
	const a, 1
	; 5:2 if a > 0
	const t.2, 0
	gt t.1, a, t.2
	branch t.1, true, @if_4_then, @if_4_else
	neg a, a
	call printIntLf@i16[a]
	jump @main_ret
@if_4_then:
	call printIntLf@i16[a]
@main_ret:

@printStringLength@@u8@i64:
	mov     rdi, rsp
	
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	mov     rdx, [rdi+18h]
	mov     r8, [rdi+10h]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

