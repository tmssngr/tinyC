@printString@@u8:
 Local variables
	arg 0: str (u8*/8)
	var 1: length (i64/8)
	; 10 pc
	call length = strlen@@u8[str] -> i64
	call printStringLength@@u8@i64[str, length]
@printString@@u8_ret:

@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	var 1: t.1 (u8*/8)
	var 2: t.2 (u8/1)
	; 12 pc
	addrof t.1, chr
	const t.2, 1
	call printStringLength@@u8@u8[t.1, t.2]
@printChar@u8_ret:

@strlen@@u8:
 Local variables
	arg 0: str (u8*/8)
	var 1: length (i64/8)
	var 2: t.2 (bool/1)
	var 3: t.3 (u8/1)
	var 4: t.4 (i64/8)
	var 5: t.5 (i64/8)
	var 6: t.6 (i64/8)
	; 50 pc
	const length, 0
	; 61:2 for *str != 0
@for_1:
	load t.3, [str]
	notequals t.2, t.3, 0
	branch t.2, false, @for_1_break, @for_1_body
@for_1_body:
	inc length
@for_1_continue:
	cast t.5(i64), str(u8*)
	const t.6, 1
	move t.4, t.5
	add t.4, t.4, t.6
	cast str(u8*), t.4(i64)
	jump @for_1
@for_1_break:
	; 64:9 return length
	ret length
	jump @strlen@@u8_ret
@strlen@@u8_ret:

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	var 2: t.2 (i64/8)
	; 10 pc
	cast t.2(i64), length(u8)
	call printStringLength@@u8@i64[str, t.2]
@printStringLength@@u8@u8_ret:

@printNibble@u8:
 Local variables
	arg 0: x (u8/1)
	var 1: t.1 (u8/1)
	var 2: t.2 (bool/1)
	; 30 pc
	const t.1, 15
	and x, x, t.1
	; 5:2 if x > 9
	gt t.2, x, 9
	branch t.2, false, @if_2_end, @if_2_then
@if_2_then:
	add x, 7
@if_2_end:
	add x, 48
	call printChar@u8[x]
@printNibble@u8_ret:

@printHex2@u8:
 Local variables
	arg 0: x (u8/1)
	var 1: t.1 (u8/1)
	var 2: t.2 (u8/1)
	; 20 pc
	const t.2, 4
	move t.1, x
	shiftright t.1, t.1, t.2
	call printNibble@u8[t.1]
	call printNibble@u8[x]
@printHex2@u8_ret:

@main:
 Local variables
	var 0: i (u8/1)
	var 1: i (u8/1)
	var 2: t.2 (u8*/8)
	var 3: t.3 (bool/1)
	var 4: t.4 (bool/1)
	var 5: t.5 (u8/1)
	var 6: t.6 (u8/1)
	var 7: t.7 (u8/1)
	var 8: t.8 (u8/1)
	var 9: t.9 (bool/1)
	var 10: t.10 (bool/1)
	var 11: t.11 (u8/1)
	var 12: t.12 (u8/1)
	var 13: t.13 (bool/1)
	var 14: t.14 (u8/1)
	var 15: t.15 (u8/1)
	var 16: t.16 (u8/1)
	var 17: t.17 (bool/1)
	var 18: t.18 (u8/1)
	var 19: t.19 (u8/1)
	var 20: t.20 (u8/1)
	; 155 pc
	; begin initialize global variables
	; end initialize global variables
	const t.2, [string-0]
	call printString@@u8[t.2]
	const i, 0
	; 19:2 for i < 16
@for_3:
	lt t.3, i, 16
	branch t.3, false, @for_3_break, @for_3_body
@for_3_body:
	; 20:3 if i & 7 == 0
	const t.6, 7
	move t.5, i
	and t.5, t.5, t.6
	equals t.4, t.5, 0
	branch t.4, false, @if_4_end, @if_4_then
@if_4_then:
	const t.7, 32
	call printChar@u8[t.7]
@if_4_end:
	call printNibble@u8[i]
@for_3_continue:
	inc i
	jump @for_3
@for_3_break:
	const t.8, 10
	call printChar@u8[t.8]
	const i, 32
	; 27:2 for i < 128
@for_5:
	lt t.9, i, 128
	branch t.9, false, @main_ret, @for_5_body
@for_5_body:
	; 28:3 if i & 15 == 0
	const t.12, 15
	move t.11, i
	and t.11, t.11, t.12
	equals t.10, t.11, 0
	branch t.10, false, @if_6_end, @if_6_then
@if_6_then:
	call printHex2@u8[i]
@if_6_end:
	; 31:3 if i & 7 == 0
	const t.15, 7
	move t.14, i
	and t.14, t.14, t.15
	equals t.13, t.14, 0
	branch t.13, false, @if_7_end, @if_7_then
@if_7_then:
	const t.16, 32
	call printChar@u8[t.16]
@if_7_end:
	call printChar@u8[i]
	; 35:3 if i & 15 == 15
	const t.19, 15
	move t.18, i
	and t.18, t.18, t.19
	equals t.17, t.18, 15
	branch t.17, false, @for_5_continue, @if_8_then
@if_8_then:
	const t.20, 10
	call printChar@u8[t.20]
@for_5_continue:
	inc i
	jump @for_5
@main_ret:

@printStringLength@@u8@i64:
	mov     rdi, rsp
	
	mov     r8, rdx
	mov     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

String literals
	string lit 0 " x\0"
