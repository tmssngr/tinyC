@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	; 7 pc
	move chr, r1
	addrof r1, chr
	const r2, 1
	call printStringLength@@u8@u8[r1, r2]

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 23 pc
	const r6, 20
	; 25:2 while true
@while_1:
	const r7, 1
	sub r6, r6, r7
	const r7, 10
	move r3, r1
	move r0, r3
	mod r2, r0, r7
	move r3, r2
	const r7, 10
	move r0, r1
	div r0, r0, r7
	move r1, r0
	cast r7(u8), r3(i64)
	const r0, 48
	add r7, r7, r0
	cast r0(i64), r6(u8)
	addrof r3, [buffer]
	add r3, r3, r0
	store [r3], r7
	; 31:3 if number == 0
	const r7, 0
	equals r7, r1, r7
	branch r7, false, @while_1, @while_1_break
	cast r7(i64), r6(u8)
	addrof r1, [buffer]
	add r1, r1, r7
	const r7, 20
	move r2, r7
	sub r2, r2, r6
	call printStringLength@@u8@u8[r1, r2]

@printIntLf@u8:
 Local variables
	arg 0: number (u8/1)
	; 2 pc
	cast r1(i64), r1(u8)
	call printIntLf@i64[r1]

@printIntLf@i64:
 Local variables
	arg 0: number (i64/8)
	; 8 pc
	move r6, r1
	; 51:2 if number < 0
	const r7, 0
	lt r7, r6, r7
	branch r7, false, @if_3_end, @if_3_then
	const r1, 45
	call printChar@u8[r1]
	neg r6, r6
@if_3_end:
	move r1, r6
	call printUint@i64[r1]
	const r1, 10
	call printChar@u8[r1]

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 2 pc
	cast r2(i64), r2(u8)
	call printStringLength@@u8@i64[r1, r2]

@initRandom@i32:
 Local variables
	arg 0: salt (i32/4)
	; 4 pc
	move r0, r1
	move __random__, r0

@random:
	; 24 pc
	move r0, __random__
	move r2, r0
	const r3, 524287
	move r4, r2
	and r4, r4, r3
	const r3, 48271
	mul r4, r4, r3
	const r1, 15
	shiftright r2, r2, r1
	const r3, 48271
	mul r2, r2, r3
	const r3, 65535
	move r5, r2
	and r5, r5, r3
	const r1, 15
	move r3, r5
	shiftleft r3, r3, r1
	const r1, 16
	shiftright r2, r2, r1
	add r2, r2, r4
	add r2, r2, r3
	const r3, 2147483647
	move r4, r2
	and r4, r4, r3
	const r1, 31
	shiftright r2, r2, r1
	move r0, r4
	add r0, r0, r2
	; 151:9 return __random__
	move __random__, r0

@randomU8:
	; 2 pc
	; 155:10 return (u8)
	call r0 = random[] -> i32
	cast r0(u8), r0(i32)

@main:
	; 11 pc
	; begin initialize global variables
	const r6, 0
	; end initialize global variables
	const r1, 7439742
	move __random__, r6
	call initRandom@i32[r1]
	const r6, 0
	; 5:2 for i < 50
	jump @for_4
@for_4_body:
	call r0 = randomU8[] -> u8
	move r1, r0
	call printIntLf@u8[r1]
	const r0, 1
	add r6, r6, r0
@for_4:
	const r0, 50
	lt r0, r6, r0
	branch r0, true, @for_4_body, @main_ret

@printStringLength@@u8@i64:
	mov     rdi, rsp
	
	mov     r8, rdx
	mov     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

Global variables
	0: __random__ (i32/4)

