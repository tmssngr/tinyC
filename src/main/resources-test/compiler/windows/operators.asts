i32 __random__;

void printString@@u8(u8* str) {
	i64 length;

	length = strlen@@u8(str);
	printStringLength@@u8@i64(str, length);
}

void printChar@u8(u8 chr) {
	printStringLength@@u8@u8(&chr, 1);
}

void printUint@i64(i64 number) {
	u8* buffer[20];
	u8 pos;
	i64 remainder;
	u8 digit;

	pos = 20;
	while (true) {
		pos = pos - 1;
		remainder = number % 10;
		number = number / 10;
		digit = ((u8)remainder) + 48;
		buffer[(i64)pos] = digit;
		if (number == 0) {
			break;
		}
	}
	printStringLength@@u8@u8(&buffer[(i64)pos], 20 - pos);
}

void printIntLf@bool(bool number) {
	printIntLf@i64((i64)number);
}

void printIntLf@u8(u8 number) {
	printIntLf@i64((i64)number);
}

void printIntLf@i16(i16 number) {
	printIntLf@i64((i64)number);
}

void printIntLf@i64(i64 number) {
	if (number < 0) {
		printChar@u8(45);
		number = -number;
	}
	printUint@i64(number);
	printChar@u8(10);
}

i64 strlen@@u8(u8* str) {
	i64 length;

	length = 0;
	for (; (*str) != 0; str = str + 1) {
		length = length + 1;
	}
	return length;
}

void printStringLength@@u8@u8(u8* str, u8 length) {
	printStringLength@@u8@i64(str, (i64)length);
}

void printStringLength@@u8@i64(u8* str, i64 length) {
}

void main() {
	i16 a;
	i16 b;
	i16 c;
	i16 d;
	bool t;
	bool f;
	u8 b10;
	u8 b6;
	u8 b1;

	printString@@u8("Bit-&:\n");
	a = 0;
	b = 1;
	c = 2;
	d = 3;
	t = true;
	f = false;
	printIntLf@i16(a & a);
	printIntLf@i16(a & b);
	printIntLf@i16(b & a);
	printIntLf@i16(b & b);
	printString@@u8("\nBit-|:\n");
	printIntLf@i16(a | a);
	printIntLf@i16(a | b);
	printIntLf@i16(b | a);
	printIntLf@i16(b | b);
	printString@@u8("\nBit-^:\n");
	printIntLf@i16(a ^ a);
	printIntLf@i16(a ^ c);
	printIntLf@i16(b ^ a);
	printIntLf@i16(b ^ c);
	printString@@u8("\nLogic-&&:\n");
	printIntLf@bool(f && f);
	printIntLf@bool(f && t);
	printIntLf@bool(t && f);
	printIntLf@bool(t && t);
	printString@@u8("\nLogic-||:\n");
	printIntLf@bool(f || f);
	printIntLf@bool(f || t);
	printIntLf@bool(t || f);
	printIntLf@bool(t || t);
	printString@@u8("\nLogic-!:\n");
	printIntLf@bool(!f);
	printIntLf@bool(!t);
	printString@@u8("\nmisc:\n");
	b10 = 10;
	b6 = 6;
	b1 = 1;
	printIntLf@u8((b10 & b6) | b1);
	printIntLf@bool((b == c) || (c < d));
	printIntLf@bool((b == c) && (c < d));
	printIntLf@i16(-1);
	printIntLf@i16(-b);
	printIntLf@u8(~b1);
}
