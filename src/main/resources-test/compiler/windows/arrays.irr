	var 15: t.15 (u8*/8)
	var 16: t.16 (u8/1)
	var 17: t.17 (u8/1)
	; 122 pc
	const pos, 20
	; 25:2 while true
@while_1:
	dec pos
	const t.5, 10
	move remainder, number
	mod remainder, remainder, t.5
	const t.6, 10
	div number, number, t.6
	cast t.7(u8), remainder(i64)
	const t.8, 48
	move digit, t.7
	add digit, digit, t.8
	cast t.10(i64), pos(u8)
	cast t.11(u8*), t.10(i64)
	addrof t.9, [buffer]
	add t.9, t.9, t.11
	store [t.9], digit
	; 31:3 if number == 0
	equals t.12, number, 0
	branch t.12, false, @while_1, @while_1_break
	cast t.14(i64), pos(u8)
	cast t.15(u8*), t.14(i64)
	addrof t.13, [buffer]
	add t.13, t.13, t.15
	const t.17, 20
	move t.16, t.17
	sub t.16, t.16, pos
	call printStringLength@@u8@u8[t.13, t.16]

@printIntLf@u8:
 Local variables
	arg 0: number (u8/1)
	var 1: t.1 (i64/8)
	; 8 pc
	cast t.1(i64), number(u8)
	call printIntLf@i64[t.1]

@printIntLf@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: t.1 (bool/1)
	var 2: t.2 (u8/1)
	var 3: t.3 (u8/1)
	; 26 pc
	; 51:2 if number < 0
	lt t.1, number, 0
	branch t.1, false, @if_3_end, @if_3_then
	const t.2, 45
	call printChar@u8[t.2]
	neg number, number
@if_3_end:
	call printUint@i64[number]
	const t.3, 10
	call printChar@u8[t.3]

@printStringLength@@u8@u8:
 Local variables
