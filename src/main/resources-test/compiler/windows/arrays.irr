	addrof t.1, chr
	const t.2, 1
	call printStringLength@@u8@u8[t.1, t.2]

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	var 2: pos (u8/1)
	var 3: remainder (i64/8)
	var 4: digit (u8/1)
	var 5: t.5 (i64/8)
	var 6: t.6 (i64/8)
