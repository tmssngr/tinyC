@printStringLength@@u8@i64:
	mov     rdi, rsp
	
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	mov     rdx, [rdi+18h]
	mov     r8, [rdi+10h]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

@getChar:
	sub    rsp, 28h
	  call [_getch]
	  test al, al
	  js   .1
	  jnz  .2
	  dec  al
	.1:
	  mov  rbx, rax
	  shl  rbx, 8
	  call [_getch]
	  or   rax, rbx
	.2:
	add    rsp, 28h
	ret

@setCursor@i16@i16:
	mov     rdi, rsp
	and     spl, 0xf0
	
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	mov     dx, [rdi+10h]
	shl     rdx, 16
	mov     dx, [rdi+18h]
	sub     rsp, 20h
	  call   [SetConsoleCursorPosition]
	mov     rsp, rdi
	ret

