@simple:
 Local variables
	var 0: four (u8/1)
	var 1: three (u8/1)
	var 2: one (u8/1)
	; 19 pc
	const four, 4
	const three, 3
	move one, four
	sub one, one, three
	; 5:9 return one
	ret one

@registerHint@u8@u8:
 Local variables
	arg 0: a (u8/1)
	arg 1: b (u8/1)
	var 2: t.2 (u8/1)
	; 15 pc
	; 9:11 return a + b
	move t.2, a
	add t.2, t.2, b
	ret t.2

@max@u8@u8:
 Local variables
	arg 0: a (u8/1)
	arg 1: b (u8/1)
	var 2: t.2 (bool/1)
	; 17 pc
	; 13:2 if a < b
	lt t.2, a, b
	branch t.2, true, @if_1_then, @if_1_end
	; 16:9 return a
	ret a
	jump @max@u8@u8_ret
@if_1_then:
	; 14:10 return b
	ret b
@max@u8@u8_ret:

@fibonacci@u8:
 Local variables
	arg 0: i (u8/1)
	var 1: a (i16/2)
	var 2: b (i16/2)
	var 3: c (i16/2)
	var 4: t.4 (bool/1)
	; 43 pc
	const a, 0
	const b, 1
	; 22:2 while i > 0
	jump @while_2
@while_2_body:
	dec i
	move c, a
	add c, c, b
	move a, b
	move b, c
@while_2:
	gt t.4, i, 0
	branch t.4, true, @while_2_body, @while_2_break
	; 28:9 return a
	ret a

@main:
 Local variables
	var 0: one (u8/1)
	var 1: two (u8/1)
	var 2: oneOrTwo (u8/1)
	var 3: f5 (i16/2)
	var 4: t.4 (u8/1)
	; 20 pc
	call one = simple[] -> u8
	const two, 2
	call _ = registerHint@u8@u8[one, two] -> u8
	call _ = max@u8@u8[one, two] -> u8
	const t.4, 5
	call _ = fibonacci@u8[t.4] -> i16

