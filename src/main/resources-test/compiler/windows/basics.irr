@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	; 7 pc
	move chr, r1
	addrof r1, chr
	const r2, 1
	call printStringLength@@u8@u8[r1, r2]

@printUint@u8:
 Local variables
	arg 0: number (u8/1)
	; 2 pc
	cast r1(i64), r1(u8)
	call printUint@i64[r1]

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 23 pc
	const r6, 20
	; 25:2 while true
@while_1:
	const r7, 1
	sub r6, r6, r7
	const r7, 10
	move r3, r1
	move r0, r3
	mod r2, r0, r7
	move r3, r2
	const r7, 10
	move r0, r1
	div r0, r0, r7
	move r1, r0
	cast r7(u8), r3(i64)
	const r0, 48
	add r7, r7, r0
	cast r0(i64), r6(u8)
	addrof r3, [buffer]
	add r3, r3, r0
	store [r3], r7
	; 31:3 if number == 0
	const r7, 0
	equals r7, r1, r7
	branch r7, false, @while_1, @while_1_break
	cast r7(i64), r6(u8)
	addrof r1, [buffer]
	add r1, r1, r7
	const r7, 20
	move r2, r7
	sub r2, r2, r6
	call printStringLength@@u8@u8[r1, r2]

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 2 pc
	cast r2(i64), r2(u8)
	call printStringLength@@u8@i64[r1, r2]

@unusedArgs@u8@bool@u8@u8:
 Local variables
	arg 0: a (u8/1)
	arg 1: b (bool/1)
	arg 2: c (u8/1)
	arg 3: d (u8/1)
	; 1 pc
	; 9:10 return (i64)
	cast r0(i64), r3(u8)

@main:
	; 37 pc
	; begin initialize global variables
	const r6, 48
	const r7, 49
	const r0, 50
	const r1, 34
	; end initialize global variables
	const r5, 1
	const r2, 1
	const r3, 2
	const r4, 3
	move zero, r6
	move one, r7
	move two, r0
	move threeFour, r1
	move r1, r5
	call _ = unusedArgs@u8@bool@u8@u8[r1, r2, r3, r4] -> i64
	move r6, zero
	move r1, r6
	call printChar@u8[r1]
	addrof r6, one
	load r1, [r6]
	call printChar@u8[r1]
	addrof r6, two
	const r7, 0
	add r6, r6, r7
	load r1, [r6]
	call printChar@u8[r1]
	move r1, threeFour
	call printUint@u8[r1]
	const r1, 10
	call printChar@u8[r1]

@printStringLength@@u8@i64:
	mov     rdi, rsp
	
	mov     r8, rdx
	mov     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

Global variables
	0: zero (u8/1)
	1: one (u8/1)
	2: two (u8/1)
	3: threeFour (u8/1)

