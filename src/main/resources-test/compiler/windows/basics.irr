@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	; 9 pc
	addrof r7, chr
	store [r7], r1
	addrof r1, chr
	const r2, 1
	call printStringLength@@u8@u8[r1, r2]

@printUint@u8:
 Local variables
	arg 0: number (u8/1)
	; 2 pc
	cast r1(i64), r1(u8)
	call printUint@i64[r1]

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 23 pc
	const r6, 20
	; 25:2 while true
@while_1:
	const r3, 1
	sub r6, r6, r3
	const r3, 10
	move r4, r1
	move r0, r4
	mod r2, r0, r3
	move r4, r2
	const r3, 10
	move r0, r1
	div r0, r0, r3
	move r1, r0
	cast r0(u8), r4(i64)
	const r3, 48
	add r0, r0, r3
	cast r3(i64), r6(u8)
	addrof r4, [buffer]
	add r4, r4, r3
	store [r4], r0
	; 31:3 if number == 0
	const r0, 0
	equals r0, r1, r0
	branch r0, false, @while_1, @while_1_break
	cast r0(i64), r6(u8)
	addrof r1, [buffer]
	add r1, r1, r0
	const r0, 20
	move r2, r0
	sub r2, r2, r6
	call printStringLength@@u8@u8[r1, r2]

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 2 pc
	cast r2(i64), r2(u8)
	call printStringLength@@u8@i64[r1, r2]

@unusedArgs@u8@bool@u8@u8:
 Local variables
	arg 0: a (u8/1)
	arg 1: b (bool/1)
	arg 2: c (u8/1)
	arg 3: d (u8/1)
	; 1 pc
	; 9:10 return (i64)
	cast r0(i64), r3(u8)

@main:
 Local variables
	var 0: t.5 (u8/1)
	var 1: t.6 (u8/1)
	; 69 pc
	; begin initialize global variables
	const r6, 48
	const r0, 49
	const r5, 50
	const r1, 34
	; end initialize global variables
	const r4, 1
	const r2, 1
	const r3, 2
	addrof r7, t.5
	store [r7], r3
	const r3, 3
	addrof r7, t.6
	store [r7], r3
	addrof r7, zero
	store [r7], r6
	addrof r7, one
	store [r7], r0
	addrof r7, two
	store [r7], r5
	addrof r7, threeFour
	store [r7], r1
	move r1, r4
	addrof r7, t.5
	load r3, [r7]
	addrof r7, t.6
	load r4, [r7]
	call _ = unusedArgs@u8@bool@u8@u8[r1, r2, r3, r4] -> i64
	addrof r7, zero
	load r6, [r7]
	move r1, r6
	call printChar@u8[r1]
	addrof r6, one
	load r1, [r6]
	call printChar@u8[r1]
	addrof r6, two
	const r0, 0
	add r6, r6, r0
	load r1, [r6]
	call printChar@u8[r1]
	addrof r7, threeFour
	load r1, [r7]
	call printUint@u8[r1]
	const r1, 10
	call printChar@u8[r1]

@printStringLength@@u8@i64:
	mov     rdi, rsp
	
	mov     r8, rdx
	mov     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

Global variables
	0: zero (u8/1)
	1: one (u8/1)
	2: two (u8/1)
	3: threeFour (u8/1)

