@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	; 9 pc
	addrof r7, chr
	store [r7], r1
	addrof r1, chr
	const r2, 1
	call printStringLength@@u8@u8[r1, r2]

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 23 pc
	const r6, 20
	; 25:2 while true
@while_1:
	const r3, 1
	sub r6, r6, r3
	const r3, 10
	move r4, r1
	move r0, r4
	mod r2, r0, r3
	move r4, r2
	const r3, 10
	move r0, r1
	div r0, r0, r3
	move r1, r0
	cast r0(u8), r4(i64)
	const r3, 48
	add r0, r0, r3
	cast r3(i64), r6(u8)
	addrof r4, [buffer]
	add r4, r4, r3
	store [r4], r0
	; 31:3 if number == 0
	const r0, 0
	equals r0, r1, r0
	branch r0, false, @while_1, @while_1_break
	cast r0(i64), r6(u8)
	addrof r1, [buffer]
	add r1, r1, r0
	const r0, 20
	move r2, r0
	sub r2, r2, r6
	call printStringLength@@u8@u8[r1, r2]

@printIntLf@i16:
 Local variables
	arg 0: number (i16/2)
	; 2 pc
	cast r1(i64), r1(i16)
	call printIntLf@i64[r1]

@printIntLf@i64:
 Local variables
	arg 0: number (i64/8)
	; 8 pc
	move r6, r1
	; 51:2 if number < 0
	const r7, 0
	lt r7, r6, r7
	branch r7, false, @if_3_end, @if_3_then
	const r1, 45
	call printChar@u8[r1]
	neg r6, r6
@if_3_end:
	move r1, r6
	call printUint@i64[r1]
	const r1, 10
	call printChar@u8[r1]

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 2 pc
	cast r2(i64), r2(u8)
	call printStringLength@@u8@i64[r1, r2]

@printAndSum@i16@i16@i16@i16@i16@i16@i16@i16:
 Local variables
	arg 0: a (i16/2)
	arg 1: b (i16/2)
	arg 2: c (i16/2)
	arg 3: d (i16/2)
	arg 4: e (i16/2)
	arg 5: f (i16/2)
	arg 6: g (i16/2)
	arg 7: h (i16/2)
	; 137 pc
	addrof r7, h
	load r6, [r7]
	addrof r7, b
	store [r7], r2
	addrof r7, c
	store [r7], r3
	addrof r7, d
	store [r7], r4
	addrof r7, a
	store [r7], r1
	call printIntLf@i16[r1]
	addrof r7, b
	load r1, [r7]
	addrof r7, b
	store [r7], r1
	call printIntLf@i16[r1]
	addrof r7, c
	load r1, [r7]
	addrof r7, c
	store [r7], r1
	call printIntLf@i16[r1]
	addrof r7, d
	load r1, [r7]
	addrof r7, d
	store [r7], r1
	call printIntLf@i16[r1]
	addrof r7, e
	load r1, [r7]
	addrof r7, e
	store [r7], r1
	call printIntLf@i16[r1]
	addrof r7, f
	load r1, [r7]
	addrof r7, f
	store [r7], r1
	call printIntLf@i16[r1]
	addrof r7, g
	load r1, [r7]
	addrof r7, g
	store [r7], r1
	call printIntLf@i16[r1]
	move r1, r6
	call printIntLf@i16[r1]
	; 17:35 return a + b + c + d + e + f + g + h
	addrof r7, a
	load r1, [r7]
	addrof r7, b
	load r2, [r7]
	add r1, r1, r2
	addrof r7, c
	load r2, [r7]
	add r1, r1, r2
	addrof r7, d
	load r2, [r7]
	add r1, r1, r2
	addrof r7, e
	load r2, [r7]
	add r1, r1, r2
	addrof r7, f
	load r2, [r7]
	add r1, r1, r2
	addrof r7, g
	load r2, [r7]
	add r1, r1, r2
	move r0, r1
	add r0, r0, r6

@main:
 Local variables
	var 0: t.4 (i16/2)
	var 1: arg.0.4 (i16/2)
	var 2: arg.0.5 (i16/2)
	var 3: arg.0.6 (i16/2)
	var 4: arg.0.7 (i16/2)
	; 41 pc
	; begin initialize global variables
	; end initialize global variables
	const r1, 1
	const r2, 2
	const r3, 3
	const r4, 4
	const r6, 5
	const r0, 6
	const r5, 7
	addrof r7, t.4
	store [r7], r4
	const r4, 8
	addrof r7, arg.0.4
	store [r7], r6
	addrof r7, arg.0.5
	store [r7], r0
	addrof r7, arg.0.6
	store [r7], r5
	addrof r7, arg.0.7
	store [r7], r4
	addrof r7, t.4
	load r4, [r7]
	call r0 = printAndSum@i16@i16@i16@i16@i16@i16@i16@i16[r1, r2, r3, r4, arg.0.4, arg.0.5, arg.0.6, arg.0.7] -> i16
	move r1, r0
	call printIntLf@i16[r1]

@printStringLength@@u8@i64:
	mov     rdi, rsp
	
	mov     r8, rdx
	mov     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

