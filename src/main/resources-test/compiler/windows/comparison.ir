	const length, 0
	; 61:2 for *str != 0
@for_4:
	load t.3, [str]
	const t.4, 0
	notequals t.2, t.3, t.4
	branch t.2, false, @for_4_break, @for_4_body
@for_4_body:
	const t.5, 1
	add length, length, t.5
@for_4_continue:
	const t.6, 1
	add str, str, t.6
	jump @for_4
@for_4_break:
	; 64:9 return length
	ret length
	jump @strlen@@u8_ret
@strlen@@u8_ret:

@printStringLength@@u8@u8:
