@printIntLf@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: t.1 (bool/1)
	var 2: t.2 (i64/8)
	var 3: t.3 (u8/1)
	var 4: t.4 (u8/1)
	; 30 pc
	; 51:2 if number < 0
	const t.2, 0
	lt t.1, number, t.2
	branch t.1, false, @if_3_end, @if_3_then
@if_3_then:
	const t.3, 45
	call printChar@u8[t.3]
	neg number, number
@if_3_end:
	call printUint@i64[number]
	const t.4, 10
	call printChar@u8[t.4]
@printIntLf@i64_ret:

@strlen@@u8:
