	move r4, r1
	move r0, r4
	mod r2, r0, r3
	move r4, r2
	const r3, 10
	move r0, r1
	div r0, r0, r3
	move r1, r0
	cast r0(u8), r4(i64)
	const r3, 48
	add r0, r0, r3
	cast r3(i64), r6(u8)
	cast r3(u8*), r3(i64)
	addrof r4, [buffer]
	add r4, r4, r3
	store [r4], r0
	; 31:3 if number == 0
	const r0, 0
	equals r0, r1, r0
	branch r0, false, @while_1, @while_1_break
	cast r0(i64), r6(u8)
	cast r0(u8*), r0(i64)
	addrof r1, [buffer]
	add r1, r1, r0
	const r0, 20
	move r2, r0
	sub r2, r2, r6
	call printStringLength@@u8@u8[r1, r2]

@printIntLf@bool:
