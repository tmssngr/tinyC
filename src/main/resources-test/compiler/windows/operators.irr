@printIntLf@i64:
 Local variables
	arg 0: number (i64/8)
	; 8 pc
	move r6, r1
	; 51:2 if number < 0
	const r7, 0
	lt r7, r6, r7
	branch r7, false, @if_3_end, @if_3_then
	const r1, 45
	call printChar@u8[r1]
	neg r6, r6
@if_3_end:
	move r1, r6
	call printUint@i64[r1]
	const r1, 10
	call printChar@u8[r1]

@strlen@@u8:
 Local variables
	arg 0: str (u8*/8)
	; 9 pc
	const r0, 0
	; 61:2 for *str != 0
	jump @for_4
@for_4_body:
	const r2, 1
	add r0, r0, r2
	cast r1(i64), r1(u8*)
	const r2, 1
	add r1, r1, r2
	cast r1(u8*), r1(i64)
@for_4:
	load r2, [r1]
	const r3, 0
	notequals r2, r2, r3
	branch r2, true, @for_4_body, @for_4_break
	; 64:9 return length

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 2 pc
	cast r2(i64), r2(u8)
	call printStringLength@@u8@i64[r1, r2]

