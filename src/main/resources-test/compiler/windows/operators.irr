@printString@@u8:
 Local variables
	arg 0: str (u8*/8)
	; 6 pc
	move r6, r1
	move r1, r6
	call r0 = strlen@@u8[r1] -> i64
	move r1, r6
	move r2, r0
	call printStringLength@@u8@i64[r1, r2]

@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	; 7 pc
	move chr, r1
	addrof r1, chr
	const r2, 1
	call printStringLength@@u8@u8[r1, r2]

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 23 pc
	const r6, 20
	; 25:2 while true
@while_1:
	const r7, 1
	sub r6, r6, r7
	const r7, 10
	move r3, r1
	move r0, r3
	mod r2, r0, r7
	move r3, r2
	const r7, 10
	move r0, r1
	div r0, r0, r7
	move r1, r0
	cast r7(u8), r3(i64)
	const r0, 48
	add r7, r7, r0
	cast r0(i64), r6(u8)
	addrof r3, [buffer]
	add r3, r3, r0
	store [r3], r7
	; 31:3 if number == 0
	const r7, 0
	equals r7, r1, r7
	branch r7, false, @while_1, @while_1_break
	cast r7(i64), r6(u8)
	addrof r1, [buffer]
	add r1, r1, r7
	const r7, 20
	move r2, r7
	sub r2, r2, r6
	call printStringLength@@u8@u8[r1, r2]

@printIntLf@bool:
 Local variables
	arg 0: number (bool/1)
	; 2 pc
	cast r1(i64), r1(bool)
	call printIntLf@i64[r1]

@printIntLf@u8:
 Local variables
	arg 0: number (u8/1)
	; 2 pc
	cast r1(i64), r1(u8)
	call printIntLf@i64[r1]

@printIntLf@i16:
 Local variables
	arg 0: number (i16/2)
	; 2 pc
	cast r1(i64), r1(i16)
	call printIntLf@i64[r1]

@printIntLf@i64:
 Local variables
	arg 0: number (i64/8)
	; 8 pc
	move r6, r1
	; 51:2 if number < 0
	const r7, 0
	lt r7, r6, r7
	branch r7, false, @if_3_end, @if_3_then
	const r1, 45
	call printChar@u8[r1]
	neg r6, r6
@if_3_end:
	move r1, r6
	call printUint@i64[r1]
	const r1, 10
	call printChar@u8[r1]

@strlen@@u8:
 Local variables
	arg 0: str (u8*/8)
	; 7 pc
	const r0, 0
	; 61:2 for *str != 0
	jump @for_4
@for_4_body:
	const r2, 1
	add r0, r0, r2
	const r2, 1
	add r1, r1, r2
@for_4:
	load r2, [r1]
	const r3, 0
	notequals r2, r2, r3
	branch r2, true, @for_4_body, @for_4_break
	; 64:9 return length

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 2 pc
	cast r2(i64), r2(u8)
	call printStringLength@@u8@i64[r1, r2]

