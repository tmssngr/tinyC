@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	var 1: t.1 (u8*/8)
	var 2: t.2 (u8/1)
	; 12 pc
	addrof t.1, chr
	const t.2, 1
	call printStringLength@@u8@u8[t.1, t.2]
@printChar@u8_ret:

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	var 2: pos (u8/1)
	var 3: remainder (i64/8)
	var 4: digit (u8/1)
	var 5: t.5 (i64/8)
	var 6: t.6 (i64/8)
	var 7: t.7 (u8/1)
	var 8: t.8 (u8/1)
	var 9: t.9 (u8*/8)
	var 10: t.10 (i64/8)
	var 11: t.11 (u8*/8)
	var 12: t.12 (bool/1)
	var 13: t.13 (u8*/8)
	var 14: t.14 (i64/8)
	var 15: t.15 (u8*/8)
	var 16: t.16 (u8/1)
	var 17: t.17 (u8/1)
	; 124 pc
	const pos, 20
	; 25:2 while true
@while_1:
	dec pos
	const t.5, 10
	move remainder, number
	mod remainder, remainder, t.5
	const t.6, 10
	div number, number, t.6
	cast t.7(u8), remainder(i64)
	const t.8, 48
	move digit, t.7
	add digit, digit, t.8
	cast t.10(i64), pos(u8)
	cast t.11(u8*), t.10(i64)
	addrof t.9, [buffer]
	add t.9, t.9, t.11
	store [t.9], digit
	; 31:3 if number == 0
	equals t.12, number, 0
	branch t.12, false, @if_2_end
	jump @while_1_break
@if_2_end:
	jump @while_1
@while_1_break:
	cast t.14(i64), pos(u8)
	cast t.15(u8*), t.14(i64)
	addrof t.13, [buffer]
	add t.13, t.13, t.15
	const t.17, 20
	move t.16, t.17
	sub t.16, t.16, pos
	call printStringLength@@u8@u8[t.13, t.16]
@printUint@i64_ret:

@printIntLf@u8:
 Local variables
	arg 0: number (u8/1)
	var 1: t.1 (i64/8)
	; 8 pc
	cast t.1(i64), number(u8)
	call printIntLf@i64[t.1]
@printIntLf@u8_ret:

@printIntLf@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: t.1 (bool/1)
	var 2: t.2 (u8/1)
	var 3: t.3 (u8/1)
	; 26 pc
	; 51:2 if number < 0
	lt t.1, number, 0
	branch t.1, false, @if_3_end
	const t.2, 45
	call printChar@u8[t.2]
	neg number, number
@if_3_end:
	call printUint@i64[number]
	const t.3, 10
	call printChar@u8[t.3]
@printIntLf@i64_ret:

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	var 2: t.2 (i64/8)
	; 10 pc
	cast t.2(i64), length(u8)
	call printStringLength@@u8@i64[str, t.2]
@printStringLength@@u8@u8_ret:

@main:
 Local variables
	var 0: i (u8/1)
	var 1: v (i16/2)
	var 2: t.2 (bool/1)
	var 3: t.3 (u8/1)
	; 29 pc
	; begin initialize global variables
	; end initialize global variables
	const i, 250
	; 4:3 for i != 2
@for_4:
	notequals t.2, i, 2
	branch t.2, false, @for_4_break
	call printIntLf@u8[i]
@for_4_continue:
	inc i
	jump @for_4
@for_4_break:
	const v, 260
	cast t.3(u8), v(i16)
	call printIntLf@u8[t.3]
@main_ret:

@printStringLength@@u8@i64:
	mov     rdi, rsp
	
	mov     r8, rdx
	mov     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

