@printString@@u8:
 Local variables
	arg 0: str (u8*/8)
	; 6 pc
	move r6, r1
	move r1, r6
	call r0 = strlen@@u8[r1] -> i64
	move r1, r6
	move r2, r0
	call printStringLength@@u8@i64[r1, r2]

@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	; 7 pc
	move chr, r1
	addrof r1, chr
	const r2, 1
	call printStringLength@@u8@u8[r1, r2]

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 25 pc
	const r6, 20
	; 25:2 while true
@while_1:
	const r7, 1
	sub r6, r6, r7
	const r7, 10
	move r3, r1
	move r0, r3
	mod r2, r0, r7
	move r3, r2
	const r7, 10
	move r0, r1
	div r0, r0, r7
	move r1, r0
	cast r7(u8), r3(i64)
	const r0, 48
	add r7, r7, r0
	cast r0(i64), r6(u8)
	cast r0(u8*), r0(i64)
	addrof r3, [buffer]
	add r3, r3, r0
	store [r3], r7
	; 31:3 if number == 0
	const r7, 0
	equals r7, r1, r7
	branch r7, false, @while_1, @while_1_break
	cast r7(i64), r6(u8)
	cast r7(u8*), r7(i64)
	addrof r1, [buffer]
	add r1, r1, r7
	const r7, 20
	move r2, r7
	sub r2, r2, r6
	call printStringLength@@u8@u8[r1, r2]

@printIntLf@bool:
 Local variables
	arg 0: number (bool/1)
	; 2 pc
	cast r1(i64), r1(bool)
	call printIntLf@i64[r1]

@printIntLf@i64:
 Local variables
	arg 0: number (i64/8)
	; 8 pc
	move r6, r1
	; 51:2 if number < 0
	const r7, 0
	lt r7, r6, r7
	branch r7, false, @if_3_end, @if_3_then
	const r1, 45
	call printChar@u8[r1]
	neg r6, r6
@if_3_end:
	move r1, r6
	call printUint@i64[r1]
	const r1, 10
	call printChar@u8[r1]

@strlen@@u8:
 Local variables
	arg 0: str (u8*/8)
	; 9 pc
	const r0, 0
	; 61:2 for *str != 0
	jump @for_4
@for_4_body:
	const r2, 1
	add r0, r0, r2
	cast r1(i64), r1(u8*)
	const r2, 1
	add r1, r1, r2
	cast r1(u8*), r1(i64)
@for_4:
	load r2, [r1]
	const r3, 0
	notequals r2, r2, r3
	branch r2, true, @for_4_body, @for_4_break
	; 64:9 return length

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 2 pc
	cast r2(i64), r2(u8)
	call printStringLength@@u8@i64[r1, r2]

@main:
 Local variables
	var 0: c (u8/1)
	var 1: d (u8/1)
	; 132 pc
	; begin initialize global variables
	; end initialize global variables
	const r1, [string-0]
	call printString@@u8[r1]
	const r6, 1
	const r7, 2
	lt r1, r6, r7
	call printIntLf@bool[r1]
	lt r1, r7, r6
	call printIntLf@bool[r1]
	const r1, [string-1]
	call printString@@u8[r1]
	const r0, 0
	const r2, 128
	lt r1, r0, r2
	move c, r0
	move d, r2
	call printIntLf@bool[r1]
	move r2, c
	move r0, d
	lt r1, r0, r2
	move c, r2
	move d, r0
	call printIntLf@bool[r1]
	const r1, [string-2]
	call printString@@u8[r1]
	lteq r1, r6, r7
	call printIntLf@bool[r1]
	lteq r1, r7, r6
	call printIntLf@bool[r1]
	const r1, [string-3]
	call printString@@u8[r1]
	move r0, c
	move r2, d
	lteq r1, r0, r2
	move c, r0
	move d, r2
	call printIntLf@bool[r1]
	move r2, c
	move r0, d
	lteq r1, r0, r2
	move c, r2
	move d, r0
	call printIntLf@bool[r1]
	const r1, [string-4]
	call printString@@u8[r1]
	equals r1, r6, r7
	call printIntLf@bool[r1]
	equals r1, r7, r6
	call printIntLf@bool[r1]
	const r1, [string-5]
	call printString@@u8[r1]
	notequals r1, r6, r7
	call printIntLf@bool[r1]
	notequals r1, r7, r6
	call printIntLf@bool[r1]
	const r1, [string-6]
	call printString@@u8[r1]
	gteq r1, r6, r7
	call printIntLf@bool[r1]
	gteq r1, r7, r6
	call printIntLf@bool[r1]
	const r1, [string-7]
	call printString@@u8[r1]
	move r0, c
	move r2, d
	gteq r1, r0, r2
	move c, r0
	move d, r2
	call printIntLf@bool[r1]
	move r2, c
	move r0, d
	gteq r1, r0, r2
	move c, r2
	move d, r0
	call printIntLf@bool[r1]
	const r1, [string-8]
	call printString@@u8[r1]
	gt r1, r6, r7
	call printIntLf@bool[r1]
	gt r1, r7, r6
	call printIntLf@bool[r1]
	const r1, [string-9]
	call printString@@u8[r1]
	move r6, c
	move r7, d
	gt r1, r6, r7
	call printIntLf@bool[r1]
	gt r1, r7, r6
	call printIntLf@bool[r1]

@printStringLength@@u8@i64:
	mov     rdi, rsp
	
	mov     r8, rdx
	mov     rdx, rcx
	lea     rcx, [hStdOut]
	mov     rcx, [rcx]
	xor     r9, r9
	push    0
	sub     rsp, 20h
	  call    [WriteFile]
	mov     rsp, rdi
	ret

String literals
	string lit 0 "< (signed)\n\0"
	string lit 1 "< (unsigned)\n\0"
	string lit 2 "<= (signed)\n\0"
	string lit 3 "<= (unsigned)\n\0"
	string lit 4 "==\n\0"
	string lit 5 "!=\n\0"
	string lit 6 ">= (signed)\n\0"
	string lit 7 ">= (unsigned)\n\0"
	string lit 8 "> (signed)\n\0"
	string lit 9 "> (unsigned)\n\0"
