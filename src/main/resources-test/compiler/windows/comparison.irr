	cast t.6(i64), str(u8*)
	const t.7, 1
	move t.5, t.6
	add t.5, t.5, t.7
	cast str(u8*), t.5(i64)
@for_4:
	load t.3, [str]
	const t.4, 0
	notequals t.2, t.3, t.4
	branch t.2, true, @for_4_body, @for_4_break
	; 64:9 return length
	ret length

