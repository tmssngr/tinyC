@printString@@u8:
 Local variables
	arg 0: str (u8*/8)
	; 6 pc
	move r6, r1
	move r1, r6
	call r0 = strlen@@u8[r1] -> i64
	move r1, r6
	move r2, r0
	call printStringLength@@u8@i64[r1, r2]

@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	; 9 pc
	addrof r7, chr
	store [r7], r1
	addrof r1, chr
	const r2, 1
	call printStringLength@@u8@u8[r1, r2]

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 25 pc
	const r6, 20
	; 25:2 while true
@while_1:
	const r3, 1
	sub r6, r6, r3
	const r3, 10
	move r4, r1
	move r0, r4
	mod r2, r0, r3
	move r4, r2
	const r3, 10
	move r0, r1
	div r0, r0, r3
	move r1, r0
	cast r0(u8), r4(i64)
	const r3, 48
	add r0, r0, r3
	cast r3(i64), r6(u8)
	cast r3(u8*), r3(i64)
	addrof r4, [buffer]
	add r4, r4, r3
	store [r4], r0
	; 31:3 if number == 0
	const r0, 0
	equals r0, r1, r0
	branch r0, false, @while_1, @while_1_break
	cast r0(i64), r6(u8)
	cast r0(u8*), r0(i64)
	addrof r1, [buffer]
	add r1, r1, r0
	const r0, 20
	move r2, r0
	sub r2, r2, r6
	call printStringLength@@u8@u8[r1, r2]

@printIntLf@bool:
 Local variables
	arg 0: number (bool/1)
	; 2 pc
	cast r1(i64), r1(bool)
	call printIntLf@i64[r1]

@printIntLf@i64:
 Local variables
	arg 0: number (i64/8)
	; 8 pc
	move r6, r1
	; 51:2 if number < 0
	const r7, 0
	lt r7, r6, r7
	branch r7, false, @if_3_end, @if_3_then
	const r1, 45
	call printChar@u8[r1]
	neg r6, r6
@if_3_end:
	move r1, r6
	call printUint@i64[r1]
	const r1, 10
	call printChar@u8[r1]

@strlen@@u8:
 Local variables
	arg 0: str (u8*/8)
	; 9 pc
	const r0, 0
	; 61:2 for *str != 0
	jump @for_4
@for_4_body:
	const r2, 1
	add r0, r0, r2
	cast r1(i64), r1(u8*)
	const r2, 1
	add r1, r1, r2
	cast r1(u8*), r1(i64)
@for_4:
	load r2, [r1]
	const r3, 0
	notequals r2, r2, r3
	branch r2, true, @for_4_body, @for_4_break
	; 64:9 return length

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 2 pc
	cast r2(i64), r2(u8)
	call printStringLength@@u8@i64[r1, r2]

@main:
