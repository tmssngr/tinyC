@printChar@u8:
 Local variables
	arg 0: chr (u8/1)
	; 9 pc
	addrof r9, chr
	store [r9], r1
	addrof r1, chr
	const r2, 1
	call printStringLength@@u8@u8[r1, r2]

@printUint@u8:
 Local variables
	arg 0: number (u8/1)
	; 2 pc
	cast r1(i64), r1(u8)
	call printUint@i64[r1]

@printUint@i64:
 Local variables
	arg 0: number (i64/8)
	var 1: buffer[] (u8*/20)
	; 23 pc
	const r8, 20
	; 21:2 while true
@while_1:
	const r4, 1
	sub r8, r8, r4
	const r4, 10
	move r5, r1
	move r0, r5
	mod r3, r0, r4
	move r5, r3
	const r4, 10
	move r0, r1
	div r0, r0, r4
	move r1, r0
	cast r0(u8), r5(i64)
	const r3, 48
	add r0, r0, r3
	cast r3(i64), r8(u8)
	addrof r4, [buffer]
	add r4, r4, r3
	store [r4], r0
	; 27:3 if number == 0
	const r0, 0
	equals r0, r1, r0
	branch r0, false, @while_1, @while_1_break
	cast r0(i64), r8(u8)
	addrof r1, [buffer]
	add r1, r1, r0
	const r0, 20
	move r2, r0
	sub r2, r2, r8
	call printStringLength@@u8@u8[r1, r2]

@printStringLength@@u8@u8:
 Local variables
	arg 0: str (u8*/8)
	arg 1: length (u8/1)
	; 2 pc
	cast r2(i64), r2(u8)
	call printStringLength@@u8@i64[r1, r2]

@unusedArgs@u8@bool@u8@u8:
 Local variables
	arg 0: a (u8/1)
	arg 1: b (bool/1)
	arg 2: c (u8/1)
	arg 3: d (u8/1)
	; 1 pc
	; 9:9 return (autocast)
	cast r0(i64), r3(u8)

@main:
	; 49 pc
	; begin initialize global variables
	const r8, 48
	const r0, 49
	const r5, 50
	const r1, 34
	; end initialize global variables
	const r6, 1
	const r2, 1
	const r3, 2
	const r4, 3
	addrof r9, zero
	store [r9], r8
	addrof r9, one
	store [r9], r0
	addrof r9, two
	store [r9], r5
	addrof r9, threeFour
	store [r9], r1
	move r1, r6
	call _ = unusedArgs@u8@bool@u8@u8[r1, r2, r3, r4] -> i64
	addrof r9, zero
	load r8, [r9]
	move r1, r8
	call printChar@u8[r1]
	addrof r8, one
	load r1, [r8]
	call printChar@u8[r1]
	addrof r8, two
	const r0, 0
	add r8, r8, r0
	load r1, [r8]
	call printChar@u8[r1]
	addrof r9, threeFour
	load r1, [r9]
	call printUint@u8[r1]
	const r1, 10
	call printChar@u8[r1]

@printStringLength@@u8@i64:
	mov rdx, rsi
	mov rsi, rdi
	mov rdi, 1
	mov rax, 1
	syscall
	ret

Global variables
	0: zero (u8/1)
	1: one (u8/1)
	2: two (u8/1)
	3: threeFour (u8/1)

