	array r1(u8* t.34), board(0@global,u8*) + r1(i64 t.31)
	load r1(u8 t.30), [r1(u8* t.34)]
	or r0(u8 pattern), r0(u8 t.26), r1(u8 t.30)
	const r1(u8 t.37), 110
