	const r3(u8 t.38), 1
	and r1(u8 t.35), r1(u8 t.36), r3(u8 t.38)
	cast r3(i64 t.39), r2(u8 j)
	array r3(u8* t.40), board(0@global,u8*) + r3(i64 t.39)
	store [r3(u8* t.40)], r1(u8 t.35)
