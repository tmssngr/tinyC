@main:
 Local variables
   var 0: i
        ; 2:9 call one
        call r0, @one ()
        ; 2:2 var i(%0)
        addrOf r1, [0@function]
        ; 2:2 assign
        store [r1], r0 (1)
        ; 3:2 call doPrint
        call @doPrint (0)
@main_ret:

@one:
        ; 7:9 return 1
        ; 7:9 int lit 1
        ld r0, 1 (1)
        IRReturnValue[reg=0, size=1]
        jmp @one_ret
@one_ret:

@doPrint:
 Local variables
   arg 0: value
   var 1: $.1
        ; 11:8 read var value(%0)
        addrOf r0, [0@argument]
        load r1, [r0] (1)
        cast r0 (i64), r1 (u8)
        ; 11:8 var $.1(%1)
        addrOf r1, [1@function]
        ; 11:8 assign
        store [r1], r0 (8)
        ; 11:8 read var $.1(%1)
        addrOf r0, [1@function]
        load r1, [r0] (8)
        ; 11:2 print i64
        printint r1
@doPrint_ret:

